---
import { getCollection } from "astro:content";
import { monthGroups, sessions } from "../data/schedule";
import { withBase } from "../lib/site";

const currentPath = Astro.url.pathname;
const noteEntries = await getCollection("classNotes");
const noteIds = new Set(noteEntries.map((entry) => entry.id));
const availableNotes = sessions.filter((session) => noteIds.has(session.slug));

const isActive = (path: string) => currentPath === path;
const startsWith = (path: string) => currentPath.startsWith(path);
const updatedParts = new Intl.DateTimeFormat("ko-KR", {
  timeZone: "Asia/Seoul",
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
  weekday: "short",
  hour: "2-digit",
  minute: "2-digit",
  second: "2-digit",
  hour12: true,
}).formatToParts(new Date());

const getPart = (type: Intl.DateTimeFormatPartTypes) =>
  updatedParts.find((part) => part.type === type)?.value ?? "";

const updatedDateLine = `${getPart("year")}년 ${getPart("month")}월 ${getPart("day")}일 (${getPart("weekday")})`;
const updatedTimeLine = `${getPart("dayPeriod")} ${getPart("hour")}:${getPart("minute")}:${getPart("second")}`;
---

<aside class="sidebar" id="shared-sidebar">
  <div class="sidebar__inner">
    <div class="sidebar__top">
      <a class="sidebar__brand" href={withBase("/")} aria-label="홈으로 이동">
        <strong>다사랑 교실</strong>
        <span>{updatedDateLine}</span>
        <span>{updatedTimeLine}</span>
      </a>
      <button
        class="sidebar__collapse"
        type="button"
        data-sidebar-toggle
        aria-controls="shared-sidebar"
        aria-label="사이드바 닫기"
        title="사이드바 닫기"
      >
        {"<"}
      </button>
    </div>

    <details class="sidebar__group" open={isActive(withBase("/"))}>
      <summary class="sidebar__summary">
        <span class="sidebar__summary-main">
          <a class="sidebar__icon-link sidebar__icon-link--overview" href={withBase("/")} aria-label="홈 전체 보기">
            <span class="sidebar__icon sidebar__icon--overview" aria-hidden="true">🏠</span>
          </a>
          <span class="sidebar__text">홈</span>
        </span>
        <span class="sidebar__arrow" aria-hidden="true"></span>
      </summary>
      <div class="sidebar__items">
        <a class:list={["sidebar__link", isActive(withBase("/")) && "is-active"]} href={withBase("/")}>
          <span class="sidebar__text">메인 허브</span>
        </a>
      </div>
    </details>

    <details
      class="sidebar__group"
      open={
        isActive(withBase("/notes/")) ||
        availableNotes.some((session) => currentPath === withBase(`/classes/${session.slug}/`))
      }
    >
      <summary class="sidebar__summary">
        <span class="sidebar__summary-main">
          <a class="sidebar__icon-link sidebar__icon-link--notes" href={withBase("/notes/")} aria-label="메모 전체 보기">
            <span class="sidebar__icon sidebar__icon--notes" aria-hidden="true">📝</span>
          </a>
          <span class="sidebar__text">메모</span>
        </span>
        <span class="sidebar__arrow" aria-hidden="true"></span>
      </summary>
      <div class="sidebar__items">
        {availableNotes.length > 0 ? (
          availableNotes.map((session) => (
            <a
              class:list={[
                "sidebar__link",
                isActive(withBase(`/classes/${session.slug}/`)) && "is-active",
              ]}
              href={withBase(`/classes/${session.slug}/`)}
            >
              <span class="sidebar__text">{session.label}</span>
            </a>
          ))
        ) : (
          <span class="sidebar__link is-empty">
            <span class="sidebar__text">작성된 메모 없음</span>
          </span>
        )}
      </div>
    </details>

    <details class="sidebar__group" open={startsWith(withBase("/classes/"))}>
      <summary class="sidebar__summary">
        <span class="sidebar__summary-main">
          <a class="sidebar__icon-link sidebar__icon-link--classes" href={withBase("/classes/")} aria-label="강의 전체 보기">
            <span class="sidebar__icon sidebar__icon--classes" aria-hidden="true">🏫</span>
          </a>
          <span class="sidebar__text">강의 목록</span>
        </span>
        <span class="sidebar__arrow" aria-hidden="true"></span>
      </summary>
      <div class="sidebar__items">
        <a
          class:list={["sidebar__link", isActive(withBase("/classes/")) && "is-active"]}
          href={withBase("/classes/")}
        >
          <span class="sidebar__text">전체 강의 목록</span>
        </a>

        {monthGroups.map(({ month, courses }) => {
          const monthOpen = courses.some(({ sessions }) =>
            sessions.some((session) => currentPath === withBase(`/classes/${session.slug}/`)),
          );

          return (
            <details class="sidebar__subgroup" open={monthOpen}>
              <summary class="sidebar__subsummary">
                <span class="sidebar__link is-month">
                  <span class="sidebar__text">{month}</span>
                </span>
                <span class="sidebar__subarrow" aria-hidden="true"></span>
              </summary>
              <div class="sidebar__subitems">
                {courses.map(({ course, sessions }) => {
                  const courseOpen = sessions.some(
                    (session) => currentPath === withBase(`/classes/${session.slug}/`),
                  );

                  return (
                    <details class="sidebar__subgroup sidebar__subgroup--course" open={courseOpen}>
                      <summary class="sidebar__subsummary sidebar__subsummary--course">
                        <span class="sidebar__link is-course">
                          <span class="sidebar__text">{course}</span>
                        </span>
                        <span class="sidebar__subarrow" aria-hidden="true"></span>
                      </summary>
                      <div class="sidebar__subitems">
                        {sessions.map((session) => (
                          <a
                            class:list={[
                              "sidebar__link",
                              "is-child",
                              currentPath === withBase(`/classes/${session.slug}/`) && "is-active",
                            ]}
                            href={withBase(`/classes/${session.slug}/`)}
                          >
                            <span class="sidebar__text">{session.label}</span>
                          </a>
                        ))}
                      </div>
                    </details>
                  );
                })}
              </div>
            </details>
          );
        })}
      </div>
    </details>
  </div>

  <div class="sidebar__footer">
    <form class="sidebar__logout" method="POST" action={withBase("/api/logout/")}>
      <button class="sidebar__logout-button" type="submit" aria-label="잠금 다시 걸기" title="잠금 다시 걸기">
        <span class="sidebar__logout-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false">
            <path
              d="M7 10V7a5 5 0 0 1 10 0v3h1a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h1zm2 0h6V7a3 3 0 0 0-6 0v3z"
              fill="currentColor"
            ></path>
          </svg>
        </span>
        <span class="sidebar__logout-label">잠금</span>
      </button>
    </form>
  </div>
</aside>

<script>
  document.querySelectorAll(".sidebar__icon-link").forEach((link) => {
    link.addEventListener("pointerdown", (event) => {
      event.stopPropagation();
    });

    link.addEventListener("click", (event) => {
      event.stopPropagation();
    });
  });
</script>

<style>
  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    width: 280px;
    overflow: hidden;
    background: #efefef;
    border-right: 1px solid #d2d2d2;
    transition: width 0.28s cubic-bezier(0.22, 1, 0.36, 1);
  }

  :global(body.sidebar-collapsed) .sidebar {
    width: 72px;
  }

  .sidebar__inner {
    flex: 1;
    min-height: 0;
    padding: 18px 16px 24px;
    overflow-y: auto;
    transition: padding 0.28s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .sidebar__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
    padding: 2px 12px 18px;
    margin-bottom: 10px;
    border-bottom: 1px solid #d2d2d2;
  }

  .sidebar__brand {
    display: block;
    min-width: 0;
    color: inherit;
    text-decoration: none;
  }

  .sidebar__brand strong {
    display: block;
    margin-bottom: 6px;
    font-size: 22px;
    line-height: 1.35;
    font-weight: 700;
  }

  .sidebar__brand span {
    display: block;
    color: #7b7b7b;
    font-size: 13px;
    line-height: 1.5;
  }

  .sidebar__collapse {
    flex: none;
    width: 34px;
    height: 34px;
    border: 1px solid #d2d2d2;
    border-radius: 8px;
    background: #ffffff;
    color: #505050;
    font: inherit;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
  }

  .sidebar__group,
  .sidebar__subgroup {
    border-top: 1px solid #d2d2d2;
  }

  .sidebar__summary,
  .sidebar__subsummary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 10px;
    list-style: none;
    cursor: pointer;
    font-size: 15px;
    font-weight: 700;
  }

  .sidebar__summary::-webkit-details-marker,
  .sidebar__subsummary::-webkit-details-marker {
    display: none;
  }

  .sidebar__subsummary {
    padding: 0;
  }

  .sidebar__summary-main {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }

  .sidebar__icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 10px;
    color: inherit;
    text-decoration: none;
  }

  .sidebar__icon-link:hover {
    background: #e5e5e5;
  }

  .sidebar__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    font-size: 16px;
    line-height: 1;
  }

  .sidebar__icon--overview {
    color: #8f5a00;
  }

  .sidebar__icon--notes {
    color: #0b6978;
  }

  .sidebar__icon--classes {
    color: #3356b4;
  }

  .sidebar__arrow::before,
  .sidebar__subarrow::before {
    content: "▸";
    color: #6f6f6f;
    font-size: 13px;
  }

  .sidebar__group[open] > .sidebar__summary .sidebar__arrow::before,
  .sidebar__subgroup[open] > .sidebar__subsummary .sidebar__subarrow::before {
    content: "▾";
  }

  .sidebar__items,
  .sidebar__subitems {
    padding: 0 0 10px;
  }

  .sidebar__link {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0 8px 8px;
    padding: 12px 14px;
    border-radius: 14px;
    color: #505050;
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
    transition: background 0.2s ease;
  }

  .sidebar__link:hover,
  .sidebar__logout-button:hover {
    background: #e8e8e8;
  }

  .sidebar__link.is-active {
    background: #efd4ae;
    color: #6d5b43;
  }

  .sidebar__link.is-empty {
    color: #8a8a8a;
    cursor: default;
  }

  .sidebar__link.is-month {
    flex: 1;
    margin: 0 8px 8px;
  }

  .sidebar__link.is-course {
    flex: 1;
    margin: 0 8px 8px 18px;
    background: #f5f5f5;
    font-size: 13px;
  }

  .sidebar__link.is-child {
    margin-left: 30px;
    font-size: 13px;
    font-weight: 600;
  }

  .sidebar__text {
    min-width: 0;
  }

  .sidebar__footer {
    flex: 0 0 auto;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    margin-top: auto;
    padding: 10px 16px 14px;
    background: #efefef;
    border-top: 1px solid #d2d2d2;
  }

  .sidebar__logout {
    margin: 0;
    width: 100%;
  }

  .sidebar__logout-button {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 8px;
    width: auto;
    min-width: 40px;
    height: 40px;
    padding: 0 8px;
    border: 1px solid transparent;
    border-radius: 12px;
    background: transparent;
    color: #8b7b6a;
    font: inherit;
    cursor: pointer;
    opacity: 0.68;
    transition:
      background 0.2s ease,
      color 0.2s ease,
      opacity 0.2s ease;
  }

  .sidebar__logout-button:hover {
    opacity: 1;
  }

  .sidebar__logout-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    color: currentColor;
  }

  .sidebar__logout-icon svg {
    width: 16px;
    height: 16px;
  }

  .sidebar__logout-label {
    color: #918476;
    font-size: 11px;
    line-height: 1;
    letter-spacing: -0.01em;
  }

  :global(body.sidebar-collapsed) .sidebar__inner {
    padding-inline: 8px;
  }

  :global(body.sidebar-collapsed) .sidebar__top {
    flex-direction: column;
    align-items: center;
    padding-inline: 0;
  }

  :global(body.sidebar-collapsed) .sidebar__brand strong,
  :global(body.sidebar-collapsed) .sidebar__brand span,
  :global(body.sidebar-collapsed) .sidebar__text,
  :global(body.sidebar-collapsed) .sidebar__arrow,
  :global(body.sidebar-collapsed) .sidebar__subarrow,
  :global(body.sidebar-collapsed) .sidebar__logout-label {
    display: none;
  }

  :global(body.sidebar-collapsed) .sidebar__collapse {
    width: 40px;
    height: 40px;
  }

  :global(body.sidebar-collapsed) .sidebar__summary,
  :global(body.sidebar-collapsed) .sidebar__subsummary {
    padding: 12px 0;
    justify-content: center;
  }

  :global(body.sidebar-collapsed) .sidebar__items,
  :global(body.sidebar-collapsed) .sidebar__subitems {
    display: none;
  }

  :global(body.sidebar-collapsed) .sidebar__link {
    justify-content: center;
    margin: 0 0 8px;
    padding: 12px;
    border-radius: 12px;
  }

  :global(body.sidebar-collapsed) .sidebar__icon-link {
    width: 30px;
    height: 30px;
    border-radius: 10px;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.04);
  }

  :global(body.sidebar-collapsed) .sidebar__icon-link--overview {
    background: #f5dfbf;
  }

  :global(body.sidebar-collapsed) .sidebar__icon-link--notes {
    background: #cfeef2;
  }

  :global(body.sidebar-collapsed) .sidebar__icon-link--classes {
    background: #d9e4ff;
  }

  :global(body.sidebar-collapsed) .sidebar__footer {
    justify-content: center;
    padding-inline: 8px;
  }

  :global(body.sidebar-collapsed) .sidebar__link.is-month,
  :global(body.sidebar-collapsed) .sidebar__link.is-course,
  :global(body.sidebar-collapsed) .sidebar__link.is-child {
    margin-left: 0;
  }

  @media (max-width: 920px) {
    .sidebar {
      width: 72px;
      z-index: 30;
    }

    :global(body.sidebar-collapsed) .sidebar {
      width: 72px;
    }
  }
</style>
