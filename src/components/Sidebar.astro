---
import { monthGroups } from "../data/schedule";

const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;

const isActive = (path: string) => currentPath === path;
const startsWith = (path: string) => currentPath.startsWith(path);

const updatedParts = new Intl.DateTimeFormat("ko-KR", {
  timeZone: "Asia/Seoul",
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
  weekday: "short",
  hour: "2-digit",
  minute: "2-digit",
  second: "2-digit",
  hour12: true,
}).formatToParts(new Date());

const getPart = (type: Intl.DateTimeFormatPartTypes) =>
  updatedParts.find((part) => part.type === type)?.value ?? "";

const updatedDateLine = `${getPart("year")}년 ${getPart("month")}월 ${getPart("day")}일 (${getPart("weekday")})`;
const updatedTimeLine = `${getPart("dayPeriod")} ${getPart("hour")} : ${getPart("minute")} : ${getPart("second")}`;
---

<aside class="sidebar" id="shared-sidebar">
  <div class="sidebar__inner">
    <div class="sidebar__top">
      <div class="sidebar__brand">
        <strong>다사랑 강의 허브</strong>
        <span>{updatedDateLine}</span>
        <span>{updatedTimeLine}</span>
      </div>
      <button
        class="sidebar__collapse"
        type="button"
        data-sidebar-toggle
        aria-controls="shared-sidebar"
        aria-label="사이드바 닫기"
        title="사이드바 닫기"
      >
        ✕
      </button>
    </div>

    <details class="sidebar__group" open={isActive(base)}>
      <summary class="sidebar__summary">
        <span>개요</span>
        <span class="sidebar__arrow" aria-hidden="true"></span>
      </summary>
      <div class="sidebar__items">
        <a class:list={["sidebar__link", isActive(base) && "is-active"]} href={base}>메인 허브</a>
        <a class="sidebar__link" href={`${base}README.md`}>프로젝트 기준</a>
      </div>
    </details>

    <details
      class="sidebar__group"
      open={startsWith(`${base}classes/260314_computer-a_01/`) || startsWith(`${base}260314_%EC%B2%AB%EC%88%98%EC%97%85/materials/`)}
    >
      <summary class="sidebar__summary">
        <span>수업 자료</span>
        <span class="sidebar__arrow" aria-hidden="true"></span>
      </summary>
      <div class="sidebar__items">
        <a
          class:list={[
            "sidebar__link",
            isActive(`${base}classes/260314_computer-a_01/`) && "is-active",
          ]}
          href={`${base}classes/260314_computer-a_01/`}
        >
          3월 14일 A반 첫 수업
        </a>
        <a
          class:list={[
            "sidebar__link",
            isActive(`${base}260314_%EC%B2%AB%EC%88%98%EC%97%85/materials/`) && "is-active",
          ]}
          href={`${base}260314_%EC%B2%AB%EC%88%98%EC%97%85/materials/`}
        >
          학생용 첫 수업 페이지
        </a>
      </div>
    </details>

    <details class="sidebar__group" open={startsWith(`${base}classes/`)}>
      <summary class="sidebar__summary">
        <span>강의 목록</span>
        <span class="sidebar__arrow" aria-hidden="true"></span>
      </summary>
      <div class="sidebar__items">
        <a class:list={["sidebar__link", isActive(`${base}classes/`) && "is-active"]} href={`${base}classes/`}>
          전체 강의 목록
        </a>

        {monthGroups.map(({ month, courses }) => {
          const monthPath = `${base}classes/#month-${month.replace("월", "")}`;
          const monthOpen = courses.some(({ sessions }) =>
            sessions.some((session) => currentPath === `${base}classes/${session.slug}/`),
          );

          return (
            <details class="sidebar__subgroup" open={monthOpen}>
              <summary class="sidebar__subsummary">
                <a class="sidebar__link is-month" href={monthPath}>{month}</a>
                <span class="sidebar__subarrow" aria-hidden="true"></span>
              </summary>
              <div class="sidebar__subitems">
                {courses.map(({ course, sessions }) => {
                  const courseOpen = sessions.some(
                    (session) => currentPath === `${base}classes/${session.slug}/`,
                  );

                  return (
                    <details class="sidebar__subgroup sidebar__subgroup--course" open={courseOpen}>
                      <summary class="sidebar__subsummary sidebar__subsummary--course">
                        <span class="sidebar__link is-course">{course}</span>
                        <span class="sidebar__subarrow" aria-hidden="true"></span>
                      </summary>
                      <div class="sidebar__subitems">
                        {sessions.map((session) => (
                          <a
                            class:list={[
                              "sidebar__link",
                              "is-child",
                              currentPath === `${base}classes/${session.slug}/` && "is-active",
                            ]}
                            href={`${base}classes/${session.slug}/`}
                          >
                            {session.label}
                          </a>
                        ))}
                      </div>
                    </details>
                  );
                })}
              </div>
            </details>
          );
        })}
      </div>
    </details>
  </div>
</aside>

<style>
  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 280px;
    overflow-y: auto;
    background: #efefef;
    border-right: 1px solid #d2d2d2;
    transition: transform 0.18s ease;
  }

  :global(body.sidebar-collapsed) .sidebar {
    transform: translateX(-100%);
  }

  .sidebar__inner {
    padding: 18px 16px 24px;
  }

  .sidebar__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
    padding: 2px 12px 18px;
    border-bottom: 1px solid #d2d2d2;
    margin-bottom: 10px;
  }

  .sidebar__brand {
    min-width: 0;
  }

  .sidebar__brand strong {
    display: block;
    margin-bottom: 6px;
    font-size: 22px;
    line-height: 1.35;
    font-weight: 700;
  }

  .sidebar__brand span {
    display: block;
    color: #7b7b7b;
    font-size: 13px;
    line-height: 1.5;
  }

  .sidebar__collapse {
    flex: none;
    width: 34px;
    height: 34px;
    border: 1px solid #d2d2d2;
    border-radius: 8px;
    background: #ffffff;
    color: #505050;
    font: inherit;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
  }

  .sidebar__group,
  .sidebar__subgroup {
    border-top: 1px solid #d2d2d2;
  }

  .sidebar__summary,
  .sidebar__subsummary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 10px;
    cursor: pointer;
    font-size: 15px;
    font-weight: 700;
  }

  .sidebar__subsummary {
    padding: 0;
  }

  .sidebar__summary::-webkit-details-marker,
  .sidebar__subsummary::-webkit-details-marker {
    display: none;
  }

  .sidebar__arrow::before,
  .sidebar__subarrow::before {
    content: "▸";
    color: #6f6f6f;
    font-size: 13px;
  }

  .sidebar__group[open] > .sidebar__summary .sidebar__arrow::before,
  .sidebar__subgroup[open] > .sidebar__subsummary .sidebar__subarrow::before {
    content: "▾";
  }

  .sidebar__items,
  .sidebar__subitems {
    padding: 0 0 10px;
  }

  .sidebar__link {
    display: block;
    margin: 0 8px 8px;
    padding: 12px 14px;
    border-radius: 14px;
    color: #505050;
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
  }

  .sidebar__link:hover {
    background: #e8e8e8;
  }

  .sidebar__link.is-active {
    background: #efd4ae;
    color: #6d5b43;
  }

  .sidebar__link.is-month {
    flex: 1;
    margin: 0 8px 8px;
  }

  .sidebar__link.is-course {
    flex: 1;
    margin: 0 8px 8px 18px;
    background: #f5f5f5;
    font-size: 13px;
    font-weight: 700;
  }

  .sidebar__link.is-child {
    margin-left: 30px;
    font-size: 13px;
    font-weight: 600;
  }

  @media (max-width: 920px) {
    .sidebar {
      position: static;
      width: auto;
      border-right: 0;
      border-bottom: 1px solid #d2d2d2;
      transform: none;
    }
  }
</style>
