---
import { monthGroups, sessions } from "../data/schedule";
import { getSlidesForSession } from "../lib/lesson-materials";
import { withBase } from "../lib/site";

const currentPath = Astro.url.pathname;
const availableMaterials = sessions.filter((session) => getSlidesForSession(session.slug).slides.length > 0);

const isActive = (path: string) => currentPath === path;
const startsWith = (path: string) => currentPath.startsWith(path);
const updatedParts = new Intl.DateTimeFormat("ko-KR", {
  timeZone: "Asia/Seoul",
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
  weekday: "short",
  hour: "2-digit",
  minute: "2-digit",
  second: "2-digit",
  hour12: true,
}).formatToParts(new Date());

const getPart = (type: Intl.DateTimeFormatPartTypes) =>
  updatedParts.find((part) => part.type === type)?.value ?? "";

const updatedDateLine = `${getPart("year")}년 ${getPart("month")}월 ${getPart("day")}일 (${getPart("weekday")})`;
const updatedTimeLine = `${getPart("dayPeriod")} ${getPart("hour")}:${getPart("minute")}:${getPart("second")}`;
---

<aside class="sidebar" id="shared-sidebar">
  <div class="sidebar__inner">
    <div class="sidebar__top">
      <a class="sidebar__brand" href={withBase("/")} aria-label="홈으로 이동">
        <strong>다사랑 교실</strong>
        <span>{updatedDateLine}</span>
        <span>{updatedTimeLine}</span>
      </a>
      <button
        class="sidebar__collapse"
        type="button"
        data-sidebar-toggle
        aria-controls="shared-sidebar"
        aria-label="사이드바 닫기"
        title="사이드바 닫기"
      >
        {"<"}
      </button>
    </div>

    <details class="sidebar__group" open={isActive(withBase("/"))}>
      <summary class="sidebar__summary">
        <span class="sidebar__label-wrap">
          <span class="sidebar__icon sidebar__icon--overview">홈</span>
          <span class="sidebar__text">개요</span>
        </span>
        <span class="sidebar__arrow" aria-hidden="true"></span>
      </summary>
      <div class="sidebar__items">
        <a class:list={["sidebar__link", isActive(withBase("/")) && "is-active"]} href={withBase("/")}>
          <span class="sidebar__text">메인 허브</span>
        </a>
      </div>
    </details>

    <details
      class="sidebar__group"
      open={
        startsWith(withBase("/260314_%EC%B2%AB%EC%88%98%EC%97%85/materials/")) ||
        availableMaterials.some((session) => startsWith(withBase(`/classes/${session.slug}/`)))
      }
    >
      <summary class="sidebar__summary">
        <span class="sidebar__label-wrap">
          <span class="sidebar__icon sidebar__icon--materials">수업</span>
          <span class="sidebar__text">대표 자료</span>
        </span>
        <span class="sidebar__arrow" aria-hidden="true"></span>
      </summary>
      <div class="sidebar__items">
        <a
          class:list={[
            "sidebar__link",
            isActive(withBase("/260314_%EC%B2%AB%EC%88%98%EC%97%85/materials/")) && "is-active",
          ]}
          href={withBase("/260314_%EC%B2%AB%EC%88%98%EC%97%85/materials/")}
        >
          <span class="sidebar__text">첫 수업 자료 페이지</span>
        </a>

        {availableMaterials.length > 0 ? (
          availableMaterials.map((session) => (
            <a
              class:list={[
                "sidebar__link",
                isActive(withBase(`/classes/${session.slug}/`)) && "is-active",
              ]}
              href={withBase(`/classes/${session.slug}/`)}
            >
              <span class="sidebar__text">{session.label}</span>
            </a>
          ))
        ) : (
          <span class="sidebar__link is-empty">
            <span class="sidebar__text">연결된 자료 없음</span>
          </span>
        )}
      </div>
    </details>

    <details class="sidebar__group" open={startsWith(withBase("/classes/"))}>
      <summary class="sidebar__summary">
        <span class="sidebar__label-wrap">
          <span class="sidebar__icon sidebar__icon--classes">반</span>
          <span class="sidebar__text">강의 목록</span>
        </span>
        <span class="sidebar__arrow" aria-hidden="true"></span>
      </summary>
      <div class="sidebar__items">
        <a
          class:list={["sidebar__link", isActive(withBase("/classes/")) && "is-active"]}
          href={withBase("/classes/")}
        >
          <span class="sidebar__text">전체 강의 목록</span>
        </a>

        {monthGroups.map(({ month, courses }) => {
          const monthOpen = courses.some(({ sessions }) =>
            sessions.some((session) => currentPath === withBase(`/classes/${session.slug}/`)),
          );

          return (
            <details class="sidebar__subgroup" open={monthOpen}>
              <summary class="sidebar__subsummary">
                <span class="sidebar__link is-month">
                  <span class="sidebar__text">{month}</span>
                </span>
                <span class="sidebar__subarrow" aria-hidden="true"></span>
              </summary>
              <div class="sidebar__subitems">
                {courses.map(({ course, sessions }) => {
                  const courseOpen = sessions.some(
                    (session) => currentPath === withBase(`/classes/${session.slug}/`),
                  );

                  return (
                    <details class="sidebar__subgroup sidebar__subgroup--course" open={courseOpen}>
                      <summary class="sidebar__subsummary sidebar__subsummary--course">
                        <span class="sidebar__link is-course">
                          <span class="sidebar__text">{course}</span>
                        </span>
                        <span class="sidebar__subarrow" aria-hidden="true"></span>
                      </summary>
                      <div class="sidebar__subitems">
                        {sessions.map((session) => (
                          <a
                            class:list={[
                              "sidebar__link",
                              "is-child",
                              currentPath === withBase(`/classes/${session.slug}/`) && "is-active",
                            ]}
                            href={withBase(`/classes/${session.slug}/`)}
                          >
                            <span class="sidebar__text">{session.label}</span>
                          </a>
                        ))}
                      </div>
                    </details>
                  );
                })}
              </div>
            </details>
          );
        })}
      </div>
    </details>
  </div>
</aside>

<style>
  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 280px;
    overflow-y: auto;
    background: #efefef;
    border-right: 1px solid #d2d2d2;
    transition:
      width 0.28s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.28s ease;
  }

  :global(body.sidebar-collapsed) .sidebar {
    width: 72px;
  }

  .sidebar__inner {
    padding: 18px 16px 24px;
    transition: padding 0.28s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .sidebar__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
    padding: 2px 12px 18px;
    border-bottom: 1px solid #d2d2d2;
    margin-bottom: 10px;
  }

  .sidebar__brand {
    display: block;
    min-width: 0;
    color: inherit;
    text-decoration: none;
  }

  .sidebar__brand strong {
    display: block;
    margin-bottom: 6px;
    font-size: 22px;
    line-height: 1.35;
    font-weight: 700;
  }

  .sidebar__brand:hover strong {
    color: #2f2f2f;
  }

  .sidebar__brand span {
    display: block;
    color: #7b7b7b;
    font-size: 13px;
    line-height: 1.5;
  }

  .sidebar__collapse {
    flex: none;
    width: 34px;
    height: 34px;
    border: 1px solid #d2d2d2;
    border-radius: 8px;
    background: #ffffff;
    color: #505050;
    font: inherit;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
  }

  .sidebar__group,
  .sidebar__subgroup {
    border-top: 1px solid #d2d2d2;
  }

  .sidebar__summary,
  .sidebar__subsummary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 10px;
    cursor: pointer;
    font-size: 15px;
    font-weight: 700;
    transition: padding 0.24s ease;
  }

  .sidebar__subsummary {
    padding: 0;
  }

  .sidebar__summary::-webkit-details-marker,
  .sidebar__subsummary::-webkit-details-marker {
    display: none;
  }

  .sidebar__label-wrap {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }

  .sidebar__arrow::before,
  .sidebar__subarrow::before {
    content: "▸";
    color: #6f6f6f;
    font-size: 13px;
  }

  .sidebar__group[open] > .sidebar__summary .sidebar__arrow::before,
  .sidebar__subgroup[open] > .sidebar__subsummary .sidebar__subarrow::before {
    content: "▾";
  }

  .sidebar__items,
  .sidebar__subitems {
    padding: 0 0 10px;
  }

  .sidebar__link {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0 8px 8px;
    padding: 12px 14px;
    border-radius: 14px;
    color: #505050;
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
  }

  .sidebar__link.is-empty {
    color: #8a8a8a;
    cursor: default;
  }

  .sidebar__icon {
    min-width: 18px;
    text-align: center;
    font-size: 12px;
  }

  .sidebar__text {
    min-width: 0;
  }

  .sidebar__link:hover {
    background: #e8e8e8;
  }

  .sidebar__link.is-active {
    background: #efd4ae;
    color: #6d5b43;
  }

  .sidebar__link.is-month {
    flex: 1;
    margin: 0 8px 8px;
  }

  .sidebar__link.is-course {
    flex: 1;
    margin: 0 8px 8px 18px;
    background: #f5f5f5;
    font-size: 13px;
    font-weight: 700;
  }

  .sidebar__link.is-child {
    margin-left: 30px;
    font-size: 13px;
    font-weight: 600;
  }

  @media (max-width: 920px) {
    .sidebar {
      position: static;
      width: auto;
      border-right: 0;
      border-bottom: 1px solid #d2d2d2;
    }
  }
</style>
