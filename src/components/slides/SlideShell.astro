---
type Props = {
  backgroundImage?: string;
  overlay?: boolean;
  shellClass?: string;
  frameClass?: string;
  imagePosition?: string;
};

const {
  backgroundImage,
  overlay = false,
  shellClass = "",
  frameClass = "",
  imagePosition = "center",
} = Astro.props;

const shellStyle =
  backgroundImage
    ? `--slide-background-image: url("${backgroundImage}"); --slide-background-position: ${imagePosition};`
    : undefined;
---

<section class:list={["slide-shell", backgroundImage && "has-background", shellClass]} style={shellStyle}>
  {overlay ? <div class="slide-shell__overlay"></div> : null}
  <div class:list={["slide-frame", "is-full-bleed", frameClass]}>
    <slot />
  </div>
</section>

<style>
  .slide-shell {
    width: 100%;
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    background: linear-gradient(180deg, #f4f1eb 0%, #e9eef5 100%);
    color: #2f3949;
  }

  .slide-shell.has-background {
    background-image: var(--slide-background-image);
    background-repeat: no-repeat;
    background-size: cover;
    background-position: var(--slide-background-position, center);
  }

  .slide-shell__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(244, 239, 232, 0.12), rgba(215, 226, 240, 0.22));
  }

  .slide-frame {
    position: relative;
    z-index: 1;
    width: 100%;
    min-height: 100vh;
    overflow: visible;
  }

  .slide-frame.is-full-bleed {
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
    backdrop-filter: none;
  }

  @media (max-width: 640px) {
    .slide-shell {
      min-height: 100vh;
    }
  }
</style>
