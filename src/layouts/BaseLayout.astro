---
import Sidebar from "../components/Sidebar.astro";

type Props = {
  title: string;
};

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root {
        --bg: #f3f3f3;
        --panel: #ffffff;
        --line: #d2d2d2;
        --text: #505050;
        --muted: #7b7b7b;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: "Malgun Gothic", "Apple SD Gothic Neo", "Noto Sans KR", sans-serif;
      }

      body.sidebar-collapsed .page-shell {
        padding-left: 0;
      }

      .page-shell {
        padding-left: 280px;
        min-height: 100vh;
        transition: padding-left 0.18s ease;
      }

      .page-main {
        padding: 24px;
      }

      .sidebar-toggle {
        position: fixed;
        top: 16px;
        left: 296px;
        z-index: 1100;
        border: 1px solid var(--line);
        background: #ffffff;
        color: #505050;
        border-radius: 10px;
        padding: 10px 12px;
        font: inherit;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
        transition: left 0.18s ease;
      }

      body.sidebar-collapsed .sidebar-toggle {
        left: 16px;
      }

      .panel {
        margin-bottom: 16px;
        padding: 18px;
        border: 1px solid var(--line);
        border-radius: 12px;
        background: var(--panel);
      }

      .panel h1,
      .panel h2 {
        margin: 0 0 12px;
        color: #424242;
        font-size: 24px;
        font-weight: 700;
      }

      .panel p {
        margin: 0;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.7;
      }

      .list {
        display: grid;
        gap: 10px;
      }

      .item {
        display: block;
        padding: 14px 16px;
        border: 1px solid var(--line);
        border-radius: 10px;
        background: #fafafa;
        color: inherit;
        text-decoration: none;
      }

      .item strong {
        display: block;
        margin-bottom: 4px;
        font-size: 15px;
        font-weight: 700;
      }

      .item span {
        display: block;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.6;
      }

      @media (max-width: 920px) {
        .sidebar-toggle {
          position: static;
          margin: 16px 16px 0;
        }

        body.sidebar-collapsed .sidebar-toggle {
          left: auto;
        }

        .page-shell {
          padding-left: 0;
        }

        .page-main {
          padding: 16px;
        }
      }
    </style>
  </head>
  <body>
    <button class="sidebar-toggle" type="button" aria-expanded="true" aria-controls="shared-sidebar">
      사이드바 닫기
    </button>
    <Sidebar />
    <div class="page-shell">
      <main class="page-main">
        <slot />
      </main>
    </div>
    <script>
      const toggleButton = document.querySelector(".sidebar-toggle");
      const storageKey = "dasarang-sidebar-collapsed";
      const applySidebarState = (collapsed) => {
        document.body.classList.toggle("sidebar-collapsed", collapsed);
        toggleButton?.setAttribute("aria-expanded", String(!collapsed));
        if (toggleButton) {
          toggleButton.textContent = collapsed ? "사이드바 열기" : "사이드바 닫기";
        }
      };

      const saved = window.localStorage.getItem(storageKey) === "true";
      applySidebarState(saved);

      toggleButton?.addEventListener("click", () => {
        const collapsed = !document.body.classList.contains("sidebar-collapsed");
        window.localStorage.setItem(storageKey, String(collapsed));
        applySidebarState(collapsed);
      });
    </script>
  </body>
</html>
