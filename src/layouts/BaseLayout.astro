---
import Sidebar from "../components/Sidebar.astro";
import { withBase } from "../lib/site";

type Props = {
  title: string;
};

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root {
        --bg: #f3f3f3;
        --panel: #ffffff;
        --line: #d2d2d2;
        --text: #505050;
        --muted: #7b7b7b;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: "Malgun Gothic", "Apple SD Gothic Neo", "Noto Sans KR", sans-serif;
      }

      body.sidebar-collapsed .page-shell {
        padding-left: 72px;
      }

      .page-shell {
        padding-left: 280px;
        min-height: 100vh;
        transition: padding-left 0.28s cubic-bezier(0.22, 1, 0.36, 1);
      }

      .page-main {
        padding: 24px;
      }

      .page-actions {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 16px;
      }

      .logout-form {
        margin: 0;
      }

      .logout-button {
        padding: 10px 14px;
        border: 1px solid var(--line);
        border-radius: 10px;
        background: #fff;
        color: var(--text);
        font: inherit;
        cursor: pointer;
      }

      .panel {
        margin-bottom: 16px;
        padding: 18px;
        border: 1px solid var(--line);
        border-radius: 12px;
        background: var(--panel);
      }

      .panel h1,
      .panel h2 {
        margin: 0 0 12px;
        color: #424242;
        font-size: 24px;
        font-weight: 700;
      }

      .panel p {
        margin: 0;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.7;
      }

      .list {
        display: grid;
        gap: 10px;
      }

      .item {
        display: block;
        padding: 14px 16px;
        border: 1px solid var(--line);
        border-radius: 10px;
        background: #fafafa;
        color: inherit;
        text-decoration: none;
      }

      .item strong {
        display: block;
        margin-bottom: 4px;
        font-size: 15px;
        font-weight: 700;
      }

      .item span {
        display: block;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.6;
      }

      @media (max-width: 920px) {
        .page-main {
          padding: 16px;
        }

        .page-actions {
          justify-content: stretch;
        }

        .logout-button {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <Sidebar />
    <div class="page-shell">
      <main class="page-main">
        <div class="page-actions">
          <form class="logout-form" method="POST" action={withBase("/api/logout/")}>
            <button class="logout-button" type="submit">잠금 다시 걸기</button>
          </form>
        </div>
        <slot />
      </main>
    </div>
    <script>
      const toggleButtons = document.querySelectorAll("[data-sidebar-toggle]");
      const sidebar = document.getElementById("shared-sidebar");
      const storageKey = "dasarang-sidebar-collapsed";
      const mobileBreakpoint = 920;

      const closeAllSidebarGroups = () => {
        sidebar?.querySelectorAll("details").forEach((group) => {
          group.open = false;
        });
      };

      const openSidebarGroup = (group) => {
        let current = group;
        while (current && current.tagName === "DETAILS") {
          current.open = true;
          current = current.parentElement?.closest("details");
        }
      };

      const isForcedCollapsed = () =>
        window.innerWidth <= mobileBreakpoint || Boolean(document.fullscreenElement);

      const applySidebarState = (collapsed) => {
        document.body.classList.toggle("sidebar-collapsed", collapsed);
        if (collapsed) {
          closeAllSidebarGroups();
        }
        toggleButtons.forEach((button) => {
          button.setAttribute("aria-expanded", String(!collapsed));
          button.setAttribute("aria-label", collapsed ? "사이드바 열기" : "사이드바 닫기");
          button.setAttribute("title", collapsed ? "사이드바 열기" : "사이드바 닫기");
          button.textContent = collapsed ? ">" : "<";
        });
      };

      const syncSidebarState = () => {
        const saved = window.localStorage.getItem(storageKey) === "true";
        applySidebarState(isForcedCollapsed() || saved);
      };

      syncSidebarState();

      toggleButtons.forEach((button) => {
        button.addEventListener("click", () => {
          if (isForcedCollapsed()) {
            return;
          }

          const collapsed = !document.body.classList.contains("sidebar-collapsed");
          window.localStorage.setItem(storageKey, String(collapsed));
          applySidebarState(collapsed);
        });
      });

      window.addEventListener("resize", syncSidebarState);
      document.addEventListener("fullscreenchange", syncSidebarState);

      sidebar?.addEventListener("click", (event) => {
        if (!document.body.classList.contains("sidebar-collapsed")) {
          return;
        }

        const summary = event.target.closest("summary");
        if (!summary) {
          return;
        }

        const group = summary.parentElement;
        if (!(group instanceof HTMLDetailsElement)) {
          return;
        }

        event.preventDefault();
        window.localStorage.setItem(storageKey, "false");
        applySidebarState(false);
        closeAllSidebarGroups();
        openSidebarGroup(group);
      });
    </script>
  </body>
</html>
