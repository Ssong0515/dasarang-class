---
import Sidebar from "../components/Sidebar.astro";

type Props = {
  title: string;
};

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root {
        --bg: #f3f3f3;
        --panel: #ffffff;
        --line: #d2d2d2;
        --text: #505050;
        --muted: #7b7b7b;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: "Malgun Gothic", "Apple SD Gothic Neo", "Noto Sans KR", sans-serif;
      }

      .page-shell {
        padding-left: 280px;
        min-height: 100vh;
      }

      .page-main {
        padding: 24px;
      }

      .panel {
        margin-bottom: 16px;
        padding: 18px;
        border: 1px solid var(--line);
        border-radius: 12px;
        background: var(--panel);
      }

      .panel h1,
      .panel h2 {
        margin: 0 0 12px;
        color: #424242;
        font-size: 24px;
        font-weight: 700;
      }

      .panel p {
        margin: 0;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.7;
      }

      .list {
        display: grid;
        gap: 10px;
      }

      .item {
        display: block;
        padding: 14px 16px;
        border: 1px solid var(--line);
        border-radius: 10px;
        background: #fafafa;
        color: inherit;
        text-decoration: none;
      }

      .item strong {
        display: block;
        margin-bottom: 4px;
        font-size: 15px;
        font-weight: 700;
      }

      .item span {
        display: block;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.6;
      }

      @media (max-width: 920px) {
        .page-shell {
          padding-left: 0;
        }

        .page-main {
          padding: 16px;
        }
      }
    </style>
  </head>
  <body>
    <Sidebar />
    <div class="page-shell">
      <main class="page-main">
        <slot />
      </main>
    </div>
  </body>
</html>

