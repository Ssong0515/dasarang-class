---
import { withBase } from "../lib/site";

type NavLink = {
  href: string;
  label: string;
};

type Props = {
  title: string;
  sessionLabel: string;
  embed?: boolean;
  currentIndex?: number;
  total?: number;
  backHref?: string;
  prevLink?: NavLink;
  nextLink?: NavLink;
  fileName?: string;
};

const {
  title,
  sessionLabel,
  embed = false,
  currentIndex = 1,
  total = 1,
  backHref = withBase("/classes/"),
  prevLink,
  nextLink,
  fileName,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root {
        color-scheme: only light;
        --preview-bg: #e7edf5;
        --preview-panel: rgba(255, 255, 255, 0.82);
        --preview-line: rgba(42, 58, 85, 0.14);
        --preview-text: #2b3850;
        --preview-muted: #6d7b92;
        --preview-accent: #1f4ac9;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        width: 100%;
        min-height: 100%;
      }

      body {
        margin: 0;
        background:
          radial-gradient(circle at top left, rgba(31, 74, 201, 0.12), transparent 32%),
          linear-gradient(180deg, #f4f7fb 0%, var(--preview-bg) 100%);
        color: var(--preview-text);
        font-family: "Malgun Gothic", "Apple SD Gothic Neo", "Noto Sans KR", sans-serif;
      }

      .preview-shell {
        min-height: 100vh;
        display: grid;
        grid-template-rows: auto 1fr;
      }

      .preview-topbar {
        position: sticky;
        top: 0;
        z-index: 10;
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: center;
        padding: 14px 20px;
        border-bottom: 1px solid var(--preview-line);
        background: rgba(244, 247, 251, 0.9);
        backdrop-filter: blur(16px);
      }

      .preview-meta {
        display: grid;
        gap: 4px;
      }

      .preview-eyebrow {
        color: var(--preview-muted);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .preview-title {
        margin: 0;
        font-size: 18px;
        font-weight: 800;
      }

      .preview-subtitle {
        color: var(--preview-muted);
        font-size: 13px;
      }

      .preview-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
      }

      .preview-chip,
      .preview-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 38px;
        padding: 0 14px;
        border-radius: 999px;
        border: 1px solid var(--preview-line);
        background: var(--preview-panel);
        color: inherit;
        text-decoration: none;
        font-size: 13px;
        font-weight: 700;
      }

      .preview-button {
        background: #fff;
        font: inherit;
        cursor: pointer;
      }

      .preview-button.is-primary {
        border-color: transparent;
        background: var(--preview-accent);
        color: #fff;
      }

      .preview-stage {
        padding: 18px;
      }

      .preview-canvas {
        width: min(1280px, calc(100vw - 36px));
        min-height: calc(100vh - 120px);
        margin: 0 auto;
        border-radius: 24px;
        border: 1px solid var(--preview-line);
        background: rgba(255, 255, 255, 0.4);
        box-shadow: 0 28px 80px rgba(24, 35, 58, 0.12);
        overflow: hidden;
      }

      .preview-stage.is-embed {
        padding: 0;
      }

      .preview-stage.is-embed .preview-canvas {
        width: 100vw;
        min-height: 100vh;
        border: 0;
        border-radius: 0;
        box-shadow: none;
      }

      @media (max-width: 920px) {
        .preview-topbar {
          padding: 12px 14px;
          flex-direction: column;
          align-items: stretch;
        }

        .preview-actions {
          justify-content: space-between;
        }

        .preview-stage {
          padding: 12px;
        }

        .preview-canvas {
          width: min(100vw - 24px, 1280px);
          min-height: calc(100vh - 160px);
          border-radius: 18px;
        }
      }
    </style>
  </head>
  <body>
    <div class="preview-shell">
      {
        !embed && (
          <header class="preview-topbar">
            <div class="preview-meta">
              <span class="preview-eyebrow">슬라이드 편집 화면</span>
              <h1 class="preview-title">{title}</h1>
              <span class="preview-subtitle">
                {sessionLabel} · {currentIndex} / {total}
                {fileName ? ` · ${fileName}` : ""}
              </span>
            </div>

            <div class="preview-actions">
              <a class="preview-button" href={backHref}>
                수업 페이지
              </a>
              <button class="preview-button" type="button" data-preview-fullscreen>
                전체화면
              </button>
              <span class="preview-chip">수정하면 바로 반영</span>
              {prevLink ? (
                <a class="preview-button" href={prevLink.href}>
                  {prevLink.label}
                </a>
              ) : null}
              {nextLink ? (
                <a class="preview-button is-primary" href={nextLink.href}>
                  {nextLink.label}
                </a>
              ) : null}
            </div>
          </header>
        )
      }

      <main class:list={["preview-stage", embed && "is-embed"]}>
        <div class="preview-canvas">
          <slot />
        </div>
      </main>
    </div>
    <script>
      const previewShell = document.querySelector(".preview-shell");
      const fullscreenButton = document.querySelector("[data-preview-fullscreen]");

      const syncFullscreenLabel = () => {
        if (!(fullscreenButton instanceof HTMLButtonElement)) return;
        fullscreenButton.textContent = document.fullscreenElement ? "전체화면 종료" : "전체화면";
      };

      syncFullscreenLabel();

      fullscreenButton?.addEventListener("click", async () => {
        if (!(previewShell instanceof HTMLElement)) return;

        if (document.fullscreenElement) {
          await document.exitFullscreen();
        } else {
          await previewShell.requestFullscreen();
        }
      });

      document.addEventListener("fullscreenchange", syncFullscreenLabel);
    </script>
  </body>
</html>
