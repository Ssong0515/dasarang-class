---
import SlideShell from "../../components/slides/SlideShell.astro";

export const slideMeta = {
  title: "명칭 알기",
  helpLabel: "장비 이름",
};
---

<SlideShell>
  <div class="names">
    <header class="names__header">
      <div class="names__hero">🖥️</div>
      <h1>명칭 알기</h1>
      <p>컴퓨터를 사용할 때 자주 보는 이름을 먼저 배웁니다</p>
      <span>Learn the names</span>
      <span>Учим названия</span>
    </header>

    <div class="names__grid">
      <article class="names__card">
        <img
          class="names__art"
          alt="모니터 일러스트"
          src="data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 600 320'%3E%3Crect width='600' height='320' fill='%23eaf3ff'/%3E%3Crect x='130' y='55' width='340' height='185' rx='18' fill='%23334155'/%3E%3Crect x='150' y='74' width='300' height='146' rx='10' fill='%2393c5fd'/%3E%3Crect x='266' y='240' width='68' height='16' rx='8' fill='%2394a3b8'/%3E%3Crect x='238' y='255' width='124' height='14' rx='7' fill='%23cbd5e1'/%3E%3Ctext x='300' y='40' font-size='28' text-anchor='middle' font-family='Arial' font-weight='700' fill='%231e293b'%3E모니터%3C/text%3E%3C/svg%3E"
        />
        <div class="names__body">
          <strong>모니터</strong>
          <p>화면을 보는 곳입니다.</p>
          <div class="names__translation">
            <span>Monitor</span>
            <span>Монитор</span>
          </div>
        </div>
      </article>

      <article class="names__card">
        <img
          class="names__art"
          alt="키보드 일러스트"
          src="data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 600 320'%3E%3Crect width='600' height='320' fill='%23eaf3ff'/%3E%3Crect x='120' y='120' width='360' height='110' rx='18' fill='%23e5e7eb' stroke='%2394a3b8' stroke-width='4'/%3E%3Cg fill='%23cbd5e1'%3E%3Crect x='150' y='145' width='34' height='18' rx='4'/%3E%3Crect x='190' y='145' width='34' height='18' rx='4'/%3E%3Crect x='230' y='145' width='34' height='18' rx='4'/%3E%3Crect x='270' y='145' width='34' height='18' rx='4'/%3E%3Crect x='310' y='145' width='34' height='18' rx='4'/%3E%3Crect x='350' y='145' width='34' height='18' rx='4'/%3E%3Crect x='390' y='145' width='58' height='18' rx='4'/%3E%3Crect x='150' y='173' width='60' height='18' rx='4'/%3E%3Crect x='216' y='173' width='34' height='18' rx='4'/%3E%3Crect x='256' y='173' width='34' height='18' rx='4'/%3E%3Crect x='296' y='173' width='108' height='18' rx='4'/%3E%3C/g%3E%3Ctext x='300' y='70' font-size='28' text-anchor='middle' font-family='Arial' font-weight='700' fill='%231e293b'%3E키보드%3C/text%3E%3C/svg%3E"
        />
        <div class="names__body">
          <strong>키보드</strong>
          <p>글자와 숫자를 입력하는 도구입니다.</p>
          <div class="names__translation">
            <span>Keyboard</span>
            <span>Клавиатура</span>
          </div>
        </div>
      </article>

      <article class="names__card">
        <img
          class="names__art"
          alt="마우스 일러스트"
          src="data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 600 320'%3E%3Crect width='600' height='320' fill='%23eaf3ff'/%3E%3Crect x='240' y='90' width='120' height='160' rx='48' fill='%23f8fafc' stroke='%2394a3b8' stroke-width='4'/%3E%3Cline x1='300' y1='115' x2='300' y2='155' stroke='%2394a3b8' stroke-width='4'/%3E%3Ctext x='300' y='60' font-size='28' text-anchor='middle' font-family='Arial' font-weight='700' fill='%231e293b'%3E마우스%3C/text%3E%3C/svg%3E"
        />
        <div class="names__body">
          <strong>마우스</strong>
          <p>움직이고 누르는 도구입니다.</p>
          <div class="names__translation">
            <span>Mouse</span>
            <span>Мышь</span>
          </div>
        </div>
      </article>

      <article class="names__card">
        <img
          class="names__art"
          alt="노트북 일러스트"
          src="data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 600 320'%3E%3Crect width='600' height='320' fill='%23eaf3ff'/%3E%3Crect x='160' y='55' width='280' height='165' rx='18' fill='%23334155'/%3E%3Crect x='180' y='74' width='240' height='126' rx='10' fill='%2393c5fd'/%3E%3Cpath d='M125 235 L475 235 L425 270 L175 270 Z' fill='%23d1d5db' stroke='%2394a3b8' stroke-width='4'/%3E%3Ctext x='300' y='40' font-size='28' text-anchor='middle' font-family='Arial' font-weight='700' fill='%231e293b'%3E노트북%3C/text%3E%3C/svg%3E"
        />
        <div class="names__body">
          <strong>노트북</strong>
          <p>화면과 키보드가 함께 있는 컴퓨터입니다.</p>
          <div class="names__translation">
            <span>Laptop</span>
            <span>Ноутбук</span>
          </div>
        </div>
      </article>
    </div>
  </div>
</SlideShell>

<style>
  .names {
    min-height: 100%;
    padding: 20px 18px 18px;
    display: flex;
    flex-direction: column;
  }

  .names__header {
    text-align: center;
  }

  .names__hero {
    font-size: 42px;
    line-height: 1;
  }

  .names__header h1 {
    margin: 8px 0 0;
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1.12;
  }

  .names__header p {
    margin: 6px 0 4px;
    font-size: clamp(15px, 1.5vw, 19px);
    line-height: 1.35;
  }

  .names__header span {
    display: block;
    font-size: 12px;
    line-height: 1.3;
    opacity: 0.88;
  }

  .names__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-top: 14px;
  }

  .names__card {
    overflow: hidden;
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.08);
  }

  .names__art {
    display: block;
    width: 100%;
    height: 154px;
    background: #eaf3ff;
  }

  .names__body {
    padding: 12px 12px 14px;
  }

  .names__body strong {
    display: block;
    margin-bottom: 6px;
    font-size: 20px;
    line-height: 1.2;
  }

  .names__body p {
    margin: 0;
    font-size: 15px;
    line-height: 1.35;
  }

  .names__translation {
    display: grid;
    gap: 3px;
    margin-top: 8px;
    font-size: 12px;
    line-height: 1.25;
    opacity: 0.86;
  }

  @media (max-width: 640px) {
    .names {
      padding: 16px 12px 14px;
    }

    .names__header h1 {
      font-size: 26px;
    }

    .names__header p {
      font-size: 13px;
    }

    .names__header span {
      font-size: 11px;
    }

    .names__grid {
      grid-template-columns: 1fr;
      gap: 10px;
      margin-top: 12px;
    }

    .names__art {
      height: 104px;
    }

    .names__body strong {
      font-size: 16px;
    }

    .names__body p {
      font-size: 13px;
    }

    .names__translation {
      font-size: 11px;
    }
  }
</style>
