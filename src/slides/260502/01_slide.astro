---
import SlideShell from "../../components/slides/SlideShell.astro";

export const slideMeta = {
  title: "slide1",
  helpLabel: "",
  order: 1,
};
---

<SlideShell>
  <div class="placeholder">
    <h1>slide1</h1>
    <p>Description</p>
  </div>
</SlideShell>

<style>
  .placeholder {
    min-height: 100%;
    display: grid;
    place-items: center;
    text-align: center;
    gap: 10px;
    padding: 24px;
  }

  .placeholder h1 {
    margin: 0;
    font-size: clamp(42px, 6vw, 72px);
    line-height: 1.1;
  }

  .placeholder p {
    margin: 0;
    font-size: clamp(18px, 2.2vw, 28px);
    opacity: 0.72;
  }
</style>
