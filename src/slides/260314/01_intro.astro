---
import SlideShell from "../../components/slides/SlideShell.astro";

export const slideMeta = {
  title: "컴퓨터 첫 수업",
  helpLabel: "첫 인사",
};
---

<SlideShell>
  <div class="intro">
    <header class="intro__header">
      <div class="intro__hero">👨‍💻</div>
      <h1 class="intro__title">컴퓨터 첫 수업</h1>

      <div class="intro__subtitle">
        <p>보고 따라 하고, 손으로 직접 해 보는 수업입니다.</p>
        <span>Learn by watching and following</span>
        <span>Учимся, глядя и повторяя</span>
      </div>
    </header>

    <div class="intro__panel">
      <div class="intro__art-box">
        <img
          class="intro__art"
          src="https://images.unsplash.com/photo-1509062522246-3755977927d7?auto=format&fit=crop&w=1200&q=80"
          alt="선생님이 설명하는 모습"
        />
      </div>

      <div class="intro__info">
        <article class="intro__item">
          <div class="intro__step">1</div>
          <div class="intro__body">
            <strong>설명 듣기</strong>
            <p>선생님이 화면을 보여 주며 천천히 설명합니다.</p>
            <span>Teacher explains step by step / Учитель объясняет шаг за шагом</span>
          </div>
        </article>

        <article class="intro__item">
          <div class="intro__step">2</div>
          <div class="intro__body">
            <strong>같이 해 보기</strong>
            <p>보고 따라 하면서 직접 눌러 보고 연습합니다.</p>
            <span>Practice together / Практикуемся вместе</span>
          </div>
        </article>
      </div>
    </div>
  </div>
</SlideShell>

<style>
  .intro {
    min-height: 100%;
    padding: 20px 18px 18px;
    display: flex;
    flex-direction: column;
  }

  .intro__header {
    text-align: center;
  }

  .intro__hero {
    font-size: 42px;
    line-height: 1;
  }

  .intro__title {
    margin: 8px 0 0;
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1.12;
  }

  .intro__subtitle {
    display: grid;
    gap: 2px;
    margin-top: 8px;
  }

  .intro__subtitle p {
    margin: 0;
    font-size: clamp(15px, 1.5vw, 19px);
    line-height: 1.35;
  }

  .intro__subtitle span {
    font-size: 12px;
    line-height: 1.3;
    opacity: 0.88;
  }

  .intro__panel {
    display: grid;
    grid-template-columns: 1.02fr 0.98fr;
    gap: 12px;
    margin-top: 14px;
    flex: 1;
  }

  .intro__art-box,
  .intro__info {
    overflow: hidden;
    min-width: 0;
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.1);
  }

  .intro__art {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .intro__info {
    padding: 14px;
    display: grid;
    gap: 10px;
    align-content: center;
  }

  .intro__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 12px;
    align-items: start;
    padding: 14px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 12px 28px rgba(15, 23, 42, 0.08);
  }

  .intro__step {
    display: inline-flex;
    width: 34px;
    height: 34px;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #ffffff;
    color: #111827;
    font-size: 16px;
    font-weight: 900;
    box-shadow: inset 0 0 0 1px rgba(148, 163, 184, 0.25);
  }

  .intro__body {
    text-align: left;
  }

  .intro__body strong {
    display: block;
    margin-bottom: 6px;
    font-size: 22px;
    font-weight: 800;
    line-height: 1.2;
  }

  .intro__body p {
    margin: 0;
    font-size: 16px;
    line-height: 1.4;
  }

  .intro__body span {
    display: block;
    margin-top: 8px;
    font-size: 12px;
    line-height: 1.35;
    opacity: 0.82;
  }

  @media (max-width: 900px) {
    .intro__body strong {
      font-size: 19px;
    }

    .intro__body p {
      font-size: 14px;
    }
  }

  @media (max-width: 640px) {
    .intro {
      padding: 16px 12px 14px;
    }

    .intro__hero {
      font-size: 34px;
    }

    .intro__title {
      font-size: 26px;
    }

    .intro__subtitle p {
      font-size: 13px;
    }

    .intro__subtitle span {
      font-size: 11px;
    }

    .intro__panel {
      grid-template-columns: 1fr;
      gap: 10px;
      margin-top: 12px;
    }

    .intro__art-box {
      min-height: 180px;
    }

    .intro__info {
      padding: 10px;
    }

    .intro__item {
      padding: 12px;
      gap: 10px;
    }

    .intro__step {
      width: 30px;
      height: 30px;
      font-size: 14px;
    }

    .intro__body strong {
      font-size: 16px;
    }

    .intro__body p {
      font-size: 13px;
    }

    .intro__body span {
      font-size: 11px;
    }
  }
</style>
