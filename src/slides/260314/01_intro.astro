---
import SlideShell from "../../components/slides/SlideShell.astro";

export const slideMeta = {
  title: "컴퓨터 수업",
  helpLabel: "첫 인사",
};
---

<SlideShell
  backgroundImage="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=1800&q=80"
  overlay
>
  <div class="intro">
    <div class="intro__hero">👨‍💻</div>
    <h1 class="intro__title">컴퓨터 수업</h1>

    <div class="intro__subtitle">
      <p>보고 따라하고, 손으로 직접 해보는 수업입니다</p>
      <span>Learn by watching and following</span>
      <span>Учимся, смотря и повторяя</span>
    </div>

    <div class="intro__grid">
      <article class="intro__card">
        <img
          src="https://images.unsplash.com/photo-1509062522246-3755977927d7?auto=format&fit=crop&w=1200&q=80"
          alt="선생님이 설명하는 모습"
        />
        <div class="intro__body">
          <strong>설명</strong>
          <p>선생님이 화면을 보며 천천히 설명합니다</p>
          <span>Teacher explains step by step / Учитель объясняет шаг за шагом</span>
        </div>
      </article>

      <article class="intro__card">
        <img
          src="https://images.unsplash.com/photo-1516321497487-e288fb19713f?auto=format&fit=crop&w=1200&q=80"
          alt="학생과 함께 실습하는 모습"
        />
        <div class="intro__body">
          <strong>연습</strong>
          <p>보고 따라하면서 같이 직접 연습합니다</p>
          <span>Practice together / Практикуем вместе</span>
        </div>
      </article>
    </div>
  </div>
</SlideShell>

<style>
  .intro {
    min-height: 100%;
    padding: 22px 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    justify-content: center;
    text-align: center;
  }

  .intro__hero {
    font-size: 64px;
    line-height: 1;
  }

  .intro__title {
    margin: 0;
    font-size: clamp(34px, 4.8vw, 58px);
    line-height: 1.1;
    font-weight: 800;
  }

  .intro__subtitle {
    display: grid;
    gap: 4px;
  }

  .intro__subtitle p {
    margin: 0;
    font-size: clamp(18px, 1.9vw, 24px);
    line-height: 1.4;
  }

  .intro__subtitle span {
    font-size: 14px;
    line-height: 1.35;
    opacity: 0.88;
  }

  .intro__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    width: 100%;
    margin-top: 10px;
  }

  .intro__card {
    overflow: hidden;
    text-align: left;
    border-radius: 22px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.08);
  }

  .intro__card img {
    display: block;
    width: 100%;
    height: 152px;
    object-fit: cover;
  }

  .intro__body {
    padding: 12px 14px 14px;
  }

  .intro__body strong {
    display: block;
    margin-bottom: 6px;
    font-size: 22px;
    font-weight: 800;
    line-height: 1.2;
  }

  .intro__body p {
    margin: 0;
    font-size: 16px;
    line-height: 1.4;
  }

  .intro__body span {
    display: block;
    margin-top: 8px;
    font-size: 13px;
    line-height: 1.3;
    opacity: 0.8;
  }

  @media (max-width: 900px) {
    .intro {
      padding: 18px 18px 20px;
    }

    .intro__grid {
      gap: 12px;
    }

    .intro__card img {
      height: 136px;
    }

    .intro__body strong {
      font-size: 19px;
    }

    .intro__body p {
      font-size: 14px;
    }
  }

  @media (max-width: 640px) {
    .intro {
      padding: 18px 14px 20px;
      justify-content: flex-start;
    }

    .intro__hero {
      font-size: 48px;
    }

    .intro__title {
      font-size: 28px;
    }

    .intro__subtitle p {
      font-size: 15px;
    }

    .intro__subtitle span {
      font-size: 12px;
    }

    .intro__grid {
      grid-template-columns: 1fr;
      gap: 10px;
      margin-top: 6px;
    }

    .intro__card img {
      height: 120px;
    }

    .intro__body {
      padding: 12px 12px 14px;
    }

    .intro__body strong {
      font-size: 17px;
    }

    .intro__body p {
      font-size: 14px;
    }

    .intro__body span {
      font-size: 11px;
    }
  }
</style>
