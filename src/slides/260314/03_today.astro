---
import SlideShell from "../../components/slides/SlideShell.astro";

export const slideMeta = {
  title: "오늘 할 것",
  helpLabel: "오늘의 순서",
};
---

<SlideShell>
  <div class="agenda">
    <header class="agenda__header">
      <div class="agenda__hero">📚</div>
      <h1>오늘 할 것</h1>
      <p>오늘 수업에서 직접 배우고 해 볼 내용을 소개합니다.</p>
      <span>What we will do today</span>
      <span>Что мы будем делать сегодня</span>
    </header>

    <div class="agenda__panel">
      <div class="agenda__art">
        <img
          src="data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1200 720'%3E%3Cdefs%3E%3ClinearGradient id='bg' x1='0' y1='0' x2='1' y2='1'%3E%3Cstop offset='0%25' stop-color='%23eff6ff'/%3E%3Cstop offset='100%25' stop-color='%23dbeafe'/%3E%3C/linearGradient%3E%3C/defs%3E%3Crect width='1200' height='720' rx='40' fill='url(%23bg)'/%3E%3Crect x='120' y='92' width='420' height='248' rx='24' fill='%23334155'/%3E%3Crect x='145' y='117' width='370' height='198' rx='14' fill='%2393c5fd'/%3E%3Crect x='250' y='360' width='320' height='98' rx='20' fill='%23e5e7eb' stroke='%2394a3b8' stroke-width='4'/%3E%3Cg fill='%23cbd5e1'%3E%3Crect x='280' y='388' width='36' height='18' rx='4'/%3E%3Crect x='322' y='388' width='36' height='18' rx='4'/%3E%3Crect x='364' y='388' width='36' height='18' rx='4'/%3E%3Crect x='406' y='388' width='36' height='18' rx='4'/%3E%3Crect x='448' y='388' width='36' height='18' rx='4'/%3E%3Crect x='490' y='388' width='48' height='18' rx='4'/%3E%3Crect x='280' y='416' width='64' height='18' rx='4'/%3E%3Crect x='350' y='416' width='36' height='18' rx='4'/%3E%3Crect x='392' y='416' width='36' height='18' rx='4'/%3E%3Crect x='434' y='416' width='104' height='18' rx='4'/%3E%3C/g%3E%3Crect x='696' y='112' width='170' height='290' rx='24' fill='%231f2937'/%3E%3Ccircle cx='780' cy='196' r='34' fill='%230f172a'/%3E%3Cpath d='M780 172 v30 M764 198 a16 16 0 1 0 32 0' stroke='%234ade80' stroke-width='10' stroke-linecap='round' fill='none'/%3E%3Ctext x='735' y='306' font-size='32' font-family='Arial,Helvetica,sans-serif' font-weight='700' fill='%23f8fafc'%3EPOWER%3C/text%3E%3Crect x='724' y='458' width='112' height='70' rx='30' fill='%23f8fafc' stroke='%2394a3b8' stroke-width='4'/%3E%3Ccircle cx='780' cy='492' r='8' fill='%2394a3b8'/%3E%3Cpath d='M540 206 C620 206 680 206 740 202' stroke='%2364748b' stroke-width='8' fill='none'/%3E%3Cpath d='M540 408 C618 432 682 452 724 458' stroke='%2364748b' stroke-width='8' fill='none'/%3E%3Ccircle cx='1018' cy='140' r='72' fill='%23ffffff' fill-opacity='0.9'/%3E%3Ctext x='978' y='152' font-size='42' font-family='Arial,Helvetica,sans-serif' font-weight='800' fill='%232563eb'%3EABC%3C/text%3E%3Crect x='910' y='360' width='180' height='132' rx='26' fill='%23ffffff' fill-opacity='0.88'/%3E%3Ctext x='946' y='414' font-size='30' font-family='Arial,Helvetica,sans-serif' font-weight='700' fill='%231e293b'%3E1 2 3%3C/text%3E%3Ctext x='930' y='458' font-size='26' font-family='Arial,Helvetica,sans-serif' font-weight='700' fill='%232563eb'%3Etyping%3C/text%3E%3C/svg%3E"
          alt="오늘 수업 순서 일러스트"
        />
      </div>

      <div class="agenda__list">
        <article class="agenda__item">
          <div class="agenda__step">1</div>
          <div class="agenda__content">
            <strong>준비하기</strong>
            <p>컴퓨터를 바르게 연결하고, 켜고, 끄는 방법을 배웁니다.</p>
            <div class="agenda__translation">
              <span>Learn how to connect the computer correctly and how to turn it on and off.</span>
              <span>Учимся правильно подключать компьютер, включать и выключать его.</span>
            </div>
          </div>
        </article>

        <article class="agenda__item">
          <div class="agenda__step">2</div>
          <div class="agenda__content">
            <strong>명칭 알기</strong>
            <p>모니터, 키보드, 마우스 이름을 정확하게 익힙니다.</p>
            <div class="agenda__translation">
              <span>Learn the names of the monitor, keyboard, and mouse.</span>
              <span>Учим названия монитора, клавиатуры и мыши.</span>
            </div>
          </div>
        </article>

        <article class="agenda__item">
          <div class="agenda__step">3</div>
          <div class="agenda__content">
            <strong>타이핑 연습</strong>
            <p>손가락으로 글자와 숫자를 입력하는 연습을 합니다.</p>
            <div class="agenda__translation">
              <span>Practice typing letters and numbers with your fingers.</span>
              <span>Практикуемся печатать буквы и цифры пальцами.</span>
            </div>
          </div>
        </article>
      </div>
    </div>
  </div>
</SlideShell>

<style>
  .agenda {
    min-height: 100%;
    padding: 20px 18px 18px;
    display: flex;
    flex-direction: column;
  }

  .agenda__header {
    text-align: center;
  }

  .agenda__hero {
    font-size: 42px;
    line-height: 1;
  }

  .agenda__header h1 {
    margin: 8px 0 0;
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1.12;
  }

  .agenda__header p {
    margin: 6px 0 4px;
    font-size: clamp(15px, 1.5vw, 19px);
    line-height: 1.35;
  }

  .agenda__header span {
    display: block;
    font-size: 12px;
    line-height: 1.3;
    opacity: 0.88;
  }

  .agenda__panel {
    display: grid;
    grid-template-columns: 1.04fr 0.96fr;
    gap: 12px;
    margin-top: 14px;
    flex: 1;
  }

  .agenda__art,
  .agenda__list {
    min-width: 0;
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.1);
  }

  .agenda__art {
    overflow: hidden;
  }

  .agenda__art img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    background: #eaf3ff;
  }

  .agenda__list {
    padding: 14px;
    display: grid;
    gap: 10px;
    align-content: center;
  }

  .agenda__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 12px;
    align-items: start;
    padding: 14px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
  }

  .agenda__step {
    display: inline-flex;
    width: 34px;
    height: 34px;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #ffffff;
    color: #111827;
    font-size: 16px;
    font-weight: 900;
    box-shadow: inset 0 0 0 1px rgba(148, 163, 184, 0.25);
  }

  .agenda__content strong {
    display: block;
    margin-bottom: 6px;
    font-size: 22px;
    line-height: 1.2;
  }

  .agenda__content p {
    margin: 0;
    font-size: 16px;
    line-height: 1.4;
  }

  .agenda__translation {
    display: grid;
    gap: 4px;
    margin-top: 8px;
    font-size: 12px;
    line-height: 1.35;
    opacity: 0.82;
  }

  @media (max-width: 900px) {
    .agenda__content strong {
      font-size: 19px;
    }

    .agenda__content p {
      font-size: 14px;
    }
  }

  @media (max-width: 640px) {
    .agenda {
      padding: 16px 12px 14px;
    }

    .agenda__header h1 {
      font-size: 26px;
    }

    .agenda__header p {
      font-size: 13px;
    }

    .agenda__header span {
      font-size: 11px;
    }

    .agenda__panel {
      grid-template-columns: 1fr;
      gap: 10px;
      margin-top: 12px;
    }

    .agenda__art {
      min-height: 180px;
    }

    .agenda__list {
      padding: 10px;
    }

    .agenda__item {
      padding: 12px;
      gap: 10px;
    }

    .agenda__step {
      width: 30px;
      height: 30px;
      font-size: 14px;
    }

    .agenda__content strong {
      font-size: 16px;
    }

    .agenda__content p {
      font-size: 13px;
    }

    .agenda__translation {
      font-size: 11px;
    }
  }
</style>
