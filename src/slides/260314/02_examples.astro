---
import SlideShell from "../../components/slides/SlideShell.astro";

export const slideMeta = {
  title: "컴퓨터로 할 수 있는 것",
  helpLabel: "인터랙션 예시",
};
---

<SlideShell>
  <div class="examples">
    <header class="examples__header">
      <div class="examples__title-row">
        <div class="examples__hero">💻</div>
        <h1>컴퓨터로 할 수 있는 것</h1>
      </div>

      <div class="examples__subtitle">
        <p>버튼을 누르면 아래 예시가 바뀝니다</p>
        <span>What you can do with a computer</span>
        <span>Что можно делать на компьютере</span>
      </div>
    </header>

    <div class="examples__chips">
      <button class="examples__chip is-active" type="button" data-example-button data-index="0">🗺️ 길 찾기</button>
      <button class="examples__chip" type="button" data-example-button data-index="1">🌐 번역</button>
      <button class="examples__chip" type="button" data-example-button data-index="2">🔎 정보 찾기</button>
      <button class="examples__chip" type="button" data-example-button data-index="3">🍜 가게 찾기</button>
      <button class="examples__chip" type="button" data-example-button data-index="4">🛒 물건 사기</button>
    </div>

    <div class="examples__panel">
      <div class="examples__image-box">
        <img
          data-example-image
          src="https://plus.unsplash.com/premium_vector-1761202026344-5bfaa5611735?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8M3x8JUVCJUFBJUE4JUVCJUIwJTk0JUVDJTlEJUJDJTIwJUVBJUI4JUI4JUVDJUIwJUJFJUVBJUI4JUIwfGVufDB8fDB8fHww"
          alt="길 찾기 예시"
        />
      </div>

      <div class="examples__info">
        <div class="examples__icon" data-example-icon>🗺️</div>
        <h2 data-example-title>길 찾기</h2>
        <p data-example-text>지도에서 목적지를 찾고 길을 확인할 수 있습니다.</p>

        <div class="examples__translations">
          <span data-example-en>Find places on a map and check directions.</span>
          <span data-example-ru>Найти место на карте и посмотреть маршрут.</span>
        </div>
      </div>
    </div>
  </div>
</SlideShell>

<script>
  const examples = [
    {
      icon: "🗺️",
      title: "길 찾기",
      text: "지도에서 목적지를 찾고 길을 확인할 수 있습니다.",
      transEn: "Find places on a map and check directions.",
      transRu: "Найти место на карте и посмотреть маршрут.",
      img: "https://plus.unsplash.com/premium_vector-1761202026344-5bfaa5611735?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8M3x8JUVCJUFBJUE4JUVCJUIwJTk0JUVDJTlEJUJDJTIwJUVBJUI4JUI4JUVDJUIwJUJFJUVBJUI4JUIwfGVufDB8fDB8fHww",
      alt: "길 찾기 예시",
    },
    {
      icon: "🌐",
      title: "번역",
      text: "한국어를 다른 언어로 바꾸고 뜻을 이해할 수 있습니다.",
      transEn: "Translate Korean into another language and understand the meaning.",
      transRu: "Перевести корейский на другой язык и понять смысл.",
      img: "https://plus.unsplash.com/premium_vector-1765037113558-15bbbb416fc6?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MTZ8fCVFQiVCMiU4OCVFQyU5NyVBRHxlbnwwfHwwfHx8MA%3D%3D",
      alt: "번역 예시",
    },
    {
      icon: "🔎",
      title: "정보 찾기",
      text: "필요한 정보와 사진을 인터넷에서 검색할 수 있습니다.",
      transEn: "Search for information and photos on the internet.",
      transRu: "Искать информацию и фотографии в интернете.",
      img: "https://plus.unsplash.com/premium_vector-1761435925322-d7beeb7c6d77?auto=format&fit=crop&fm=jpg&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&ixlib=rb-4.1.0&q=60&w=3000",
      alt: "검색창과 돋보기가 있는 정보 찾기 일러스트",
    },
    {
      icon: "🍜",
      title: "가게 찾기",
      text: "음식점과 카페 위치를 보고 선택할 수 있습니다.",
      transEn: "Find restaurants and cafes and choose where to go.",
      transRu: "Найти кафе и рестораны и выбрать, куда пойти.",
      img: "https://plus.unsplash.com/premium_vector-1747619131786-29eb111bfe52?auto=format&fit=crop&fm=jpg&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&ixlib=rb-4.1.0&q=60&w=3000",
      alt: "위치 표시와 가게 태그가 있는 가게 찾기 일러스트",
    },
    {
      icon: "🛒",
      title: "물건 사기",
      text: "인터넷에서 필요한 물건을 찾아 주문할 수 있습니다.",
      transEn: "Find and order things you need on the internet.",
      transRu: "Найти и заказать нужные вещи в интернете.",
      img: "https://plus.unsplash.com/premium_vector-1726815518466-ddd2e0d0d65b?auto=format&fit=crop&fm=jpg&ixid=M3wxMjA3fDB8MHxwaG90by1pbi1zYW1lLXNlcmllc3wzfHx8ZW58MHx8fHx8&ixlib=rb-4.1.0&q=60&w=3000",
      alt: "온라인 쇼핑 화면과 카트가 있는 물건 사기 일러스트",
    },
  ];

  const chips = Array.from(document.querySelectorAll("[data-example-button]"));
  const image = document.querySelector("[data-example-image]");
  const icon = document.querySelector("[data-example-icon]");
  const title = document.querySelector("[data-example-title]");
  const text = document.querySelector("[data-example-text]");
  const transEn = document.querySelector("[data-example-en]");
  const transRu = document.querySelector("[data-example-ru]");

  const applyExample = (index) => {
    const data = examples[index];
    if (!data || !(image instanceof HTMLImageElement)) return;
    image.src = data.img;
    image.alt = data.alt;
    if (icon) icon.textContent = data.icon;
    if (title) title.textContent = data.title;
    if (text) text.textContent = data.text;
    if (transEn) transEn.textContent = data.transEn;
    if (transRu) transRu.textContent = data.transRu;
    chips.forEach((chip, chipIndex) => {
      chip.classList.toggle("is-active", chipIndex === index);
    });
  };

  chips.forEach((chip, index) => {
    chip.addEventListener("click", () => applyExample(index));
  });
</script>

<style>
  .examples {
    min-height: 100%;
    padding: 20px 20px 20px;
    display: flex;
    flex-direction: column;
  }

  .examples__header {
    text-align: center;
  }

  .examples__title-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
  }

  .examples__hero {
    font-size: 38px;
    line-height: 1;
  }

  .examples__header h1 {
    margin: 0;
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1.1;
  }

  .examples__subtitle {
    display: grid;
    gap: 2px;
    margin-top: 8px;
  }

  .examples__subtitle p {
    margin: 0;
    font-size: clamp(15px, 1.5vw, 19px);
    line-height: 1.35;
  }

  .examples__subtitle span {
    font-size: 12px;
    line-height: 1.3;
    opacity: 0.88;
  }

  .examples__chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin: 14px 0 12px;
  }

  .examples__chip {
    min-height: 38px;
    padding: 8px 14px;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.22);
    background: rgba(255, 255, 255, 0.88);
    box-shadow: 0 8px 18px rgba(15, 23, 42, 0.08);
    color: inherit;
    font: inherit;
    cursor: pointer;
  }

  .examples__chip.is-active {
    background: #fff;
    color: #15203a;
    font-weight: 700;
  }

  .examples__panel {
    display: grid;
    grid-template-columns: 1.04fr 0.96fr;
    gap: 14px;
    flex: 1;
  }

  .examples__image-box,
  .examples__info {
    min-width: 0;
    border-radius: 20px;
    border: 1px solid rgba(148, 163, 184, 0.22);
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 12px 28px rgba(15, 23, 42, 0.08);
  }

  .examples__image-box {
    overflow: hidden;
  }

  .examples__image-box img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .examples__info {
    padding: 18px;
    display: grid;
    align-content: center;
    gap: 10px;
  }

  .examples__icon {
    font-size: 36px;
    line-height: 1;
  }

  .examples__info h2 {
    margin: 0;
    font-size: 28px;
  }

  .examples__info p {
    margin: 0;
    font-size: 18px;
    line-height: 1.45;
  }

  .examples__translations {
    display: grid;
    gap: 6px;
    margin-top: 6px;
    font-size: 14px;
    line-height: 1.4;
    opacity: 0.88;
  }

  @media (max-width: 900px) {
    .examples {
      padding: 16px 16px 16px;
    }

    .examples__panel {
      gap: 12px;
    }

    .examples__info {
      padding: 13px;
    }

    .examples__info h2 {
      font-size: 19px;
    }

    .examples__info p {
      font-size: 14px;
    }
  }

  @media (max-width: 640px) {
    .examples {
      padding: 14px 14px 16px;
    }

    .examples__title-row {
      gap: 8px;
    }

    .examples__hero {
      font-size: 34px;
    }

    .examples__header h1 {
      font-size: 26px;
    }

    .examples__subtitle p {
      font-size: 14px;
    }

    .examples__subtitle span {
      font-size: 12px;
    }

    .examples__chips {
      margin: 8px 0 10px;
      gap: 6px;
    }

    .examples__chip {
      padding: 8px 10px;
      font-size: 12px;
    }

    .examples__panel {
      grid-template-columns: 1fr;
    }

    .examples__image-box {
      min-height: 180px;
    }

    .examples__info {
      padding: 14px;
    }

    .examples__icon {
      font-size: 30px;
    }

    .examples__info h2 {
      font-size: 20px;
    }

    .examples__info p {
      font-size: 14px;
      line-height: 1.35;
    }

    .examples__translations {
      font-size: 11px;
    }
  }
</style>
