---
import { withBase } from "../lib/site";

const next = Astro.url.searchParams.get("next") ?? withBase("/");
const hasError = Astro.url.searchParams.get("error") === "1";
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>다사랑 교실 잠금 해제</title>
    <style>
      :root {
        --bg: #f4efe5;
        --panel: rgba(255, 255, 255, 0.92);
        --line: rgba(122, 101, 67, 0.18);
        --text: #42301d;
        --muted: #725a40;
        --accent: #8f5a00;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 24px;
        background:
          radial-gradient(circle at top, rgba(255, 223, 175, 0.55), transparent 35%),
          linear-gradient(180deg, #f8f2e8 0%, #efe5d7 100%);
        color: var(--text);
        font-family: "Malgun Gothic", "Apple SD Gothic Neo", "Noto Sans KR", sans-serif;
      }

      .card {
        width: min(100%, 420px);
        padding: 28px;
        border: 1px solid var(--line);
        border-radius: 20px;
        background: var(--panel);
        box-shadow: 0 24px 80px rgba(78, 52, 24, 0.12);
      }

      h1 {
        margin: 0 0 10px;
        font-size: 28px;
      }

      p {
        margin: 0 0 20px;
        color: var(--muted);
        line-height: 1.7;
      }

      label {
        display: block;
        margin-bottom: 8px;
        font-weight: 700;
      }

      input {
        width: 100%;
        padding: 14px 16px;
        border: 1px solid rgba(122, 101, 67, 0.26);
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.9);
        font: inherit;
      }

      button {
        width: 100%;
        margin-top: 14px;
        padding: 14px 16px;
        border: 0;
        border-radius: 12px;
        background: linear-gradient(135deg, #9f6d15 0%, #7a4d00 100%);
        color: #fff8ef;
        font: inherit;
        font-weight: 700;
        cursor: pointer;
      }

      .error {
        margin-bottom: 16px;
        padding: 12px 14px;
        border-radius: 12px;
        background: rgba(189, 74, 41, 0.12);
        color: #8f2d10;
        font-size: 14px;
      }
    </style>
  </head>
  <body>
    <main class="card">
      <h1>잠금 해제</h1>
      <p>이 사이트는 비밀번호를 입력해야 열립니다. 비밀번호를 입력하면 같은 브라우저에서 계속 접근할 수 있습니다.</p>

      {hasError && <div class="error">비밀번호가 올바르지 않습니다.</div>}

      <form method="POST" action={withBase("/api/login")}>
        <input type="hidden" name="next" value={next} />
        <label for="password">비밀번호</label>
        <input id="password" name="password" type="password" required autocomplete="current-password" />
        <button type="submit">들어가기</button>
      </form>
    </main>
  </body>
</html>
