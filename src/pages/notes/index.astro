---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sessions } from "../../data/schedule";
import { listNotes } from "../../lib/notes";
import { withBase } from "../../lib/site";

const notes = await listNotes(Astro.locals);
const sessionMap = new Map(sessions.map((session) => [session.slug, session]));
const rows = Object.entries(notes)
  .map(([slug, note]) => {
    const session = sessionMap.get(slug);
    if (!session || !note.content.trim()) {
      return undefined;
    }

    return { slug, note, session };
  })
  .filter(Boolean)
  .sort((left, right) => left!.session.date.localeCompare(right!.session.date)) as Array<{
    slug: string;
    note: (typeof notes)[string];
    session: (typeof sessions)[number];
  }>;
---

<BaseLayout title="전체 메모">
  <section class="panel">
    <h1>전체 메모</h1>
    <p>저장한 수업 메모를 날짜순으로 모아 봅니다. 각 카드에서 해당 수업 상세 페이지로 바로 이동할 수 있습니다.</p>
  </section>

  {rows.length > 0 ? (
    <div class="notes-grid">
      {rows.map(({ slug, note, session }) => (
        <article class="panel note-card" id={slug}>
          <div class="note-card__head">
            <div>
              <h2>{session.label}</h2>
              <p class="note-card__meta">
                <span>{session.course}</span>
                <span>{session.date}</span>
                <span>{session.time}</span>
              </p>
            </div>
            <a class="note-card__link" href={withBase(`/classes/${slug}/`)}>
              수업 상세
            </a>
          </div>
          <div class="note-card__body">{note.content}</div>
        </article>
      ))}
    </div>
  ) : (
    <section class="panel">
      <p>아직 저장된 메모가 없습니다.</p>
    </section>
  )}
</BaseLayout>

<style>
  .notes-grid {
    display: grid;
    gap: 16px;
  }

  .note-card {
    display: grid;
    gap: 16px;
  }

  .note-card__head {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-start;
  }

  .note-card__head h2 {
    margin-bottom: 8px;
    font-size: 20px;
  }

  .note-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 12px;
    color: #7b7b7b;
    font-size: 13px;
  }

  .note-card__link {
    flex: none;
    padding: 10px 14px;
    border-radius: 999px;
    background: #1c2434;
    color: #fff;
    text-decoration: none;
    font-size: 13px;
    font-weight: 700;
  }

  .note-card__body {
    padding: 18px;
    border: 1px solid #dcdcdc;
    border-radius: 12px;
    background: #fcfcfc;
    white-space: pre-wrap;
    line-height: 1.8;
  }

  @media (max-width: 720px) {
    .note-card__head {
      flex-direction: column;
    }
  }
</style>
