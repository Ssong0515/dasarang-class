---
import SlidePreviewLayout from "../../../layouts/SlidePreviewLayout.astro";
import { sessions } from "../../../data/schedule";
import { getSlidesForSession, loadComponentSlide } from "../../../lib/lesson-materials";
import { withBase } from "../../../lib/site";

const slug = Astro.params.slug ?? "";
const slideId = Astro.params.slide ?? "";
const material = await getSlidesForSession(slug);
const loaded = await loadComponentSlide(slug, slideId);
const embed = Astro.url.searchParams.get("embed") === "1";
const session =
  sessions.find((entry) => entry.slug === slug) ??
  sessions.find((entry) => entry.slug.startsWith(`${slug.slice(0, 6)}_`));

if (material.source !== "component" || !loaded || !session) {
  Astro.response.status = 404;
}

const componentSlides = material.slides.filter((entry) => entry.kind === "component");
const currentIndex = componentSlides.findIndex((entry) => entry.slideId === slideId);
const previous = currentIndex > 0 ? componentSlides[currentIndex - 1] : undefined;
const next = currentIndex >= 0 && currentIndex < componentSlides.length - 1 ? componentSlides[currentIndex + 1] : undefined;
const SlideComponent = loaded?.component;
---

{
  loaded && session && SlideComponent ? (
    <SlidePreviewLayout
      title={loaded.meta.title}
      sessionLabel={session.label}
      embed={embed}
      currentIndex={currentIndex + 1}
      total={componentSlides.length}
      fileName={loaded.meta.fileName}
      backHref={withBase(`/classes/${slug}/`)}
      prevLink={
        previous
          ? {
              href: withBase(previous.previewPath),
              label: "이전 슬라이드",
            }
          : undefined
      }
      nextLink={
        next
          ? {
              href: withBase(next.previewPath),
              label: "다음 슬라이드",
            }
          : undefined
      }
    >
      <SlideComponent />
    </SlidePreviewLayout>
  ) : (
    <SlidePreviewLayout title="슬라이드를 찾을 수 없습니다" sessionLabel="Slide Preview" embed={embed}>
      <div
        style="min-height:100vh;display:grid;place-items:center;background:#172033;color:#fff;font-family:'Malgun Gothic','Apple SD Gothic Neo','Noto Sans KR',sans-serif;"
      >
        슬라이드를 찾을 수 없습니다.
      </div>
    </SlidePreviewLayout>
  )
}
