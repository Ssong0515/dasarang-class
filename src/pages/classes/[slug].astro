---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sessions } from "../../data/schedule";
import { getSlidesForSession } from "../../lib/lesson-materials";
import type { SlideDocument } from "../../lib/lesson-materials";
import { getNote } from "../../lib/notes";
import { withBase } from "../../lib/site";

export const prerender = false;

const slug = Astro.params.slug ?? "";
const session = sessions.find((entry) => entry.slug === slug);

if (!session) {
  Astro.response.status = 404;
}

const note = session ? await getNote(slug, Astro.locals) : undefined;
const material = session
  ? await getSlidesForSession(slug)
  : { slides: [], slidesDir: undefined, source: "none" as const };
const slides = material.slides ?? [];
const isComponentSlideDeck = material.source === "component";
type ComponentSlide = Extract<SlideDocument, { kind: "component" }>;
const componentSlides = slides.filter((slide): slide is ComponentSlide => slide.kind === "component");
const startClassHref = componentSlides[0] ? withBase(componentSlides[0].previewPath) : undefined;
const slideApiPath = withBase(`/api/slides/${slug}/`);
const importableSessions = sessions.filter((entry) => entry.slug !== slug);
---

<BaseLayout title={session ? session.label : "수업을 찾을 수 없습니다"}>
  {
    session ? (
      <>
        <section class="panel lesson-header">
          <div class="lesson-header__title">
            <div class="lesson-header__heading">
              <h1>{session.label}</h1>
              <span class="lesson-header__schedule">{session.date} / {session.time}</span>
            </div>
            <p>{session.summary}</p>
          </div>
        </section>

        <section class="panel">
          <details class="note-panel" data-note-panel>
            <summary class="note-panel__summary">
              <div>
                <h2>수업 메모</h2>
                <p class="section-copy">필요한 내용만 적어두고, 닫아두면 다시 깔끔해집니다.</p>
              </div>
              <div class="note-panel__meta">
                {
                  note?.updatedAt ? (
                    <span class="section-meta">
                      마지막 저장{" "}
                      {new Intl.DateTimeFormat("ko-KR", {
                        dateStyle: "medium",
                        timeStyle: "short",
                        timeZone: "Asia/Seoul",
                      }).format(new Date(note.updatedAt))}
                    </span>
                  ) : (
                    <span class="section-meta">아직 저장한 메모 없음</span>
                  )
                }
                <span class="note-panel__arrow" aria-hidden="true"></span>
              </div>
            </summary>

            <div class="note-panel__body">
              <form class="note-form" method="POST" action={withBase(`/api/notes/${slug}/`)} data-note-form>
                <textarea
                  class="note-textarea"
                  name="content"
                  rows={14}
                  placeholder="오늘 수업 이름, 주제, 아이디어, 준비할 것들을 자유롭게 적어보세요."
                >{note?.content ?? ""}</textarea>
                <div class="note-actions">
                  <p class="save-notice" data-note-status aria-live="polite"></p>
                  <button class="note-save" type="submit">저장</button>
                </div>
              </form>
            </div>
          </details>
        </section>

        {isComponentSlideDeck && componentSlides.length > 0 ? (
          <section class="panel material-panel">
            <div class="section-head">
              <h2>슬라이드</h2>
            </div>

            <div class="workspace-panel">
              <div class="workspace-panel__meta">
                <div class="workspace-panel__heading">
                  <strong>슬라이드 목록</strong>
                  <span class="section-badge" data-slide-count-badge>{componentSlides.length}장</span>
                </div>
              </div>
              <div class="workspace-panel__actions">
                <button class="workspace-panel__button is-import" type="button" data-slide-import-open>
                  가져오기
                </button>
                {startClassHref ? (
                  <a class="workspace-panel__button" href={startClassHref} data-start-class-button>
                    수업 시작
                  </a>
                ) : null}
              </div>
            </div>

            <dialog class="slide-import-dialog" data-slide-import-dialog>
              <form class="slide-import-dialog__panel" method="dialog">
                <div class="slide-import-dialog__head">
                  <strong>다른 수업 슬라이드 가져오기</strong>
                  <button class="slide-import-dialog__close" type="submit" value="cancel" aria-label="닫기">×</button>
                </div>
                <p class="slide-import-dialog__copy">선택한 수업의 슬라이드를 현재 목록 아래에 이어서 추가합니다.</p>
                <select class="slide-import-dialog__select" data-slide-import-select>
                  <option value="">가져올 수업 선택</option>
                  {importableSessions.map((entry) => (
                    <option value={entry.slug}>{entry.label}</option>
                  ))}
                </select>
                <div class="slide-import-dialog__actions">
                  <button class="slide-import-dialog__button is-cancel" type="submit" value="cancel">취소</button>
                  <button class="slide-import-dialog__button is-confirm" type="button" data-slide-import-confirm>
                    가져오기
                  </button>
                </div>
              </form>
            </dialog>

            <div
              class="component-slide-list"
              data-slide-list
              data-slide-api={slideApiPath}
            >
              {componentSlides.map((slide, index) => (
                <article
                  class="component-slide-card"
                  draggable="true"
                  data-slide-card
                  data-slide-id={slide.slideId}
                  data-slide-href={withBase(slide.previewPath)}
                >
                  <button
                    class="component-slide-card__handle"
                    type="button"
                    data-slide-handle
                    aria-label={`${slide.title} 순서 이동`}
                    title="드래그해서 순서 이동"
                  >
                    ⋮⋮
                  </button>
                  <span class="component-slide-card__index" data-slide-order-label>
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <div class="component-slide-card__body">
                      <input
                        class="component-slide-card__title-input is-plain"
                        type="text"
                        value={slide.title}
                        data-slide-title-input
                        aria-label="슬라이드 제목"
                      />
                      <input
                        class="component-slide-card__help-input is-plain"
                        type="text"
                        value={slide.helpLabel || ""}
                        placeholder="설명 입력"
                        data-slide-help-input
                        aria-label="슬라이드 설명"
                      />
                  </div>
                  <div class="component-slide-card__actions">
                    <a class="component-slide-card__button is-edit" href={withBase(slide.previewPath)}>
                      편집
                    </a>
                    <button class="component-slide-card__button is-delete" type="button" data-slide-delete>
                      삭제
                    </button>
                  </div>
                </article>
              ))}
            </div>

            <button class="component-slide-add" type="button" data-slide-add aria-label="슬라이드 추가">
              +
            </button>
            <p class="component-slide-list__empty" data-slide-empty hidden>표시할 슬라이드가 없습니다.</p>
          </section>
        ) : (
          <section class="panel empty-panel">
            <h2>자료 연결 대기</h2>
            <p>이 수업에는 아직 사용할 컴포넌트 슬라이드가 없습니다.</p>
            <a class="empty-panel__link" href={withBase("/classes/")}>강의 목록으로 돌아가기</a>
          </section>
        )}
      </>
    ) : (
      <section class="panel">
        <h1>수업을 찾을 수 없습니다</h1>
        <p>요청한 수업 슬러그에 해당하는 일정이 없습니다.</p>
      </section>
    )
  }
</BaseLayout>

<script>
  const notePanel = document.querySelector("[data-note-panel]");
  const noteForm = document.querySelector("[data-note-form]");
  const noteStatus = document.querySelector("[data-note-status]");
  const slideList = document.querySelector("[data-slide-list]");
  const slideCountBadge = document.querySelector("[data-slide-count-badge]");
  const emptySlideMessage = document.querySelector("[data-slide-empty]");
  const startClassButton = document.querySelector("[data-start-class-button]");
  const addSlideButton = document.querySelector("[data-slide-add]");
  const importDialog = document.querySelector("[data-slide-import-dialog]");
  const importOpenButton = document.querySelector("[data-slide-import-open]");
  const importConfirmButton = document.querySelector("[data-slide-import-confirm]");
  const importSelect = document.querySelector("[data-slide-import-select]");

  if (notePanel instanceof HTMLDetailsElement && noteForm instanceof HTMLFormElement) {
    noteForm.addEventListener("submit", async (event) => {
      event.preventDefault();

      const submitButton = noteForm.querySelector('button[type="submit"]');
      if (!(submitButton instanceof HTMLButtonElement)) return;

      submitButton.disabled = true;
      if (noteStatus instanceof HTMLElement) {
        noteStatus.textContent = "저장 중...";
      }

      try {
        const response = await fetch(noteForm.action, {
          method: "POST",
          body: new FormData(noteForm),
          headers: {
            Accept: "application/json",
          },
        });

        if (!response.ok) {
          throw new Error("save_failed");
        }

        notePanel.open = false;
        if (noteStatus instanceof HTMLElement) {
          noteStatus.textContent = "저장했습니다.";
        }
      } catch {
        if (noteStatus instanceof HTMLElement) {
          noteStatus.textContent = "저장에 실패했습니다.";
        }
      } finally {
        submitButton.disabled = false;
      }
    });
  }

  if (slideList instanceof HTMLElement) {
    const apiPath = slideList.dataset.slideApi || "";
    let draggedCard = null;

    const getCards = () =>
      Array.from(slideList.querySelectorAll("[data-slide-card]")).filter(
        (entry) => entry instanceof HTMLElement,
      );

    const syncSlideState = () => {
      const cards = getCards();

      cards.forEach((card, index) => {
        const orderLabel = card.querySelector("[data-slide-order-label]");
        if (orderLabel instanceof HTMLElement) {
          orderLabel.textContent = String(index + 1).padStart(2, "0");
        }
      });

      if (slideCountBadge instanceof HTMLElement) {
        slideCountBadge.textContent = `${cards.length}장`;
      }

      if (emptySlideMessage instanceof HTMLElement) {
        emptySlideMessage.hidden = cards.length > 0;
      }

      if (startClassButton instanceof HTMLAnchorElement) {
        const firstCard = cards[0];
        const href = firstCard?.dataset.slideHref;

        if (href) {
          startClassButton.href = href;
          startClassButton.removeAttribute("aria-disabled");
          startClassButton.classList.remove("is-disabled");
        } else {
          startClassButton.removeAttribute("href");
          startClassButton.setAttribute("aria-disabled", "true");
          startClassButton.classList.add("is-disabled");
        }
      }
    };

    const persistOrder = async () => {
      if (!apiPath) return;

      const order = getCards()
        .map((card) => card.dataset.slideId)
        .filter((entry): entry is string => Boolean(entry));

      await fetch(apiPath, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: JSON.stringify({
          action: "reorder",
          order,
        }),
      });
    };

    const getDropTarget = (clientY) => {
      const cards = getCards().filter((card) => card !== draggedCard);

      return cards.reduce(
        (closest, card) => {
          const box = card.getBoundingClientRect();
          const offset = clientY - box.top - box.height / 2;

          if (offset < 0 && offset > closest.offset) {
            return { offset, element: card };
          }

          return closest;
        },
        { offset: Number.NEGATIVE_INFINITY, element: null },
      ).element;
    };

    slideList.addEventListener("dragstart", (event) => {
      const target = event.target;
      const card = target instanceof HTMLElement ? target.closest("[data-slide-card]") : null;
      if (!(card instanceof HTMLElement)) return;

      draggedCard = card;
      card.classList.add("is-dragging");
      event.dataTransfer?.setData("text/plain", card.dataset.slideId || "");
      if (event.dataTransfer) {
        event.dataTransfer.effectAllowed = "move";
      }
    });

    slideList.addEventListener("dragend", async () => {
      if (draggedCard instanceof HTMLElement) {
        draggedCard.classList.remove("is-dragging");
      }

      draggedCard = null;
      syncSlideState();
      await persistOrder();
    });

    slideList.addEventListener("dragover", (event) => {
      if (!(draggedCard instanceof HTMLElement)) return;

      event.preventDefault();
      const target = getDropTarget(event.clientY);

      if (target instanceof HTMLElement) {
        slideList.insertBefore(draggedCard, target);
      } else {
        slideList.appendChild(draggedCard);
      }
    });

    slideList.addEventListener("click", async (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;

      const deleteButton = target.closest("[data-slide-delete]");
      const card = target.closest("[data-slide-card]");

      if (!(card instanceof HTMLElement)) return;

      if (deleteButton instanceof HTMLElement) {
        const slideId = card.dataset.slideId;
        if (!slideId || !apiPath) return;

        const confirmed = window.confirm("이 슬라이드를 이 수업 목록에서 삭제할까요?");
        if (!confirmed) return;

        const response = await fetch(apiPath, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify({
            action: "delete",
            slideId,
          }),
        });

        if (!response.ok) {
          window.alert("삭제에 실패했습니다.");
          return;
        }

        card.remove();
        syncSlideState();
      }
    });

    const saveTimers = new WeakMap();

    const setCardDirty = (card, dirty) => {
      if (!(card instanceof HTMLElement)) return;
      card.dataset.dirty = dirty ? "true" : "false";
    };

    const saveCardMeta = async (card) => {
      if (!(card instanceof HTMLElement)) return;

      const slideId = card.dataset.slideId;
      if (!slideId || !apiPath) return;

      const titleInput = card.querySelector("[data-slide-title-input]");
      const helpInput = card.querySelector("[data-slide-help-input]");

      if (!(titleInput instanceof HTMLInputElement) || !(helpInput instanceof HTMLInputElement)) {
        return;
      }

      const response = await fetch(apiPath, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: JSON.stringify({
          action: "update-meta",
          slideId,
          title: titleInput.value.trim() || "제목 없음",
          helpLabel: helpInput.value.trim(),
        }),
      });

      if (!response.ok) {
        window.alert("텍스트 저장에 실패했습니다.");
        return;
      }

      titleInput.value = titleInput.value.trim() || "제목 없음";
      helpInput.value = helpInput.value.trim();
      setCardDirty(card, false);
    };

    slideList.addEventListener("input", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement)) return;

      const card = target.closest("[data-slide-card]");
      if (!(card instanceof HTMLElement)) return;
      setCardDirty(card, true);

      const previousTimer = saveTimers.get(card);
      if (previousTimer) {
        window.clearTimeout(previousTimer);
      }

      const nextTimer = window.setTimeout(() => {
        saveCardMeta(card);
        saveTimers.delete(card);
      }, 450);

      saveTimers.set(card, nextTimer);
    });

    slideList.addEventListener("keydown", async (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement)) return;
      if (!(event.key === "Enter" && (event.metaKey || event.ctrlKey))) return;

      const card = target.closest("[data-slide-card]");
      await saveCardMeta(card);
    });

    slideList.addEventListener("focusout", async (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement)) return;

      const card = target.closest("[data-slide-card]");
      if (!(card instanceof HTMLElement) || card.dataset.dirty !== "true") return;

      const previousTimer = saveTimers.get(card);
      if (previousTimer) {
        window.clearTimeout(previousTimer);
        saveTimers.delete(card);
      }

      await saveCardMeta(card);
    });

    syncSlideState();
  }

  addSlideButton?.addEventListener("click", async () => {
    if (!(addSlideButton instanceof HTMLButtonElement) || !(slideList instanceof HTMLElement)) return;

    const apiPath = slideList.dataset.slideApi || "";
    if (!apiPath) return;

    addSlideButton.disabled = true;

    try {
      const response = await fetch(apiPath, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: JSON.stringify({
          action: "add",
        }),
      });

      if (!response.ok) {
        throw new Error("add_failed");
      }

      window.location.reload();
    } catch {
      window.alert("슬라이드 추가에 실패했습니다.");
      addSlideButton.disabled = false;
    }
  });

  importOpenButton?.addEventListener("click", () => {
    if (!(importDialog instanceof HTMLDialogElement)) return;
    importDialog.showModal();
  });

  importConfirmButton?.addEventListener("click", async () => {
    if (!(slideList instanceof HTMLElement) || !(importSelect instanceof HTMLSelectElement)) return;
    if (!(importConfirmButton instanceof HTMLButtonElement)) return;

    const sourceSlug = importSelect.value;
    const apiPath = slideList.dataset.slideApi || "";

    if (!sourceSlug || !apiPath) {
      window.alert("가져올 수업을 먼저 선택해주세요.");
      return;
    }

    const confirmed = window.confirm("선택한 수업의 슬라이드를 현재 목록 아래에 추가할까요?");
    if (!confirmed) return;

    importConfirmButton.disabled = true;

    try {
      const response = await fetch(apiPath, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: JSON.stringify({
          action: "import",
          sourceSlug,
        }),
      });

      if (!response.ok) {
        throw new Error("import_failed");
      }

      if (importDialog instanceof HTMLDialogElement) {
        importDialog.close();
      }

      window.location.reload();
    } catch {
      window.alert("슬라이드 가져오기에 실패했습니다.");
      importConfirmButton.disabled = false;
    }
  });
</script>

<style>
  .lesson-header {
    background: linear-gradient(180deg, #ffffff 0%, #fcfaf7 100%);
  }

  .lesson-header__heading {
    display: flex;
    gap: 12px;
    align-items: baseline;
    flex-wrap: wrap;
  }

  .lesson-header__schedule {
    color: #7d7568;
    font-size: 14px;
    font-weight: 700;
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    align-items: center;
    margin-bottom: 12px;
  }

  .section-copy {
    margin: 6px 0 0;
    color: #7b7b7b;
    font-size: 13px;
    line-height: 1.7;
  }

  .section-meta {
    color: #7b7b7b;
    font-size: 12px;
    font-weight: 700;
  }

  .section-badge {
    padding: 8px 12px;
    border-radius: 999px;
    background: #eef6ff;
    color: #24538a;
    font-size: 12px;
    font-weight: 800;
  }

  .workspace-panel {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: center;
    margin-top: 14px;
    padding: 18px;
    border: 1px solid #d8e2ef;
    border-radius: 16px;
    background: linear-gradient(180deg, #f7fbff 0%, #eef5fc 100%);
  }

  .workspace-panel__meta {
    display: grid;
    gap: 6px;
  }

  .workspace-panel__heading {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .workspace-panel__meta strong {
    color: #25466f;
    font-size: 15px;
  }

  .workspace-panel__meta span {
    color: #5f7289;
    font-size: 13px;
    line-height: 1.65;
  }

  .workspace-panel__actions {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .workspace-panel__button {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 16px;
    border-radius: 999px;
    background: #1c2434;
    color: #fff;
    text-decoration: none;
    font-size: 13px;
    font-weight: 800;
    border: 0;
    cursor: pointer;
  }

  .workspace-panel__button.is-import {
    background: #edf6ff;
    color: #235091;
    border: 1px solid #cfe1f8;
  }

  .workspace-panel__button.is-disabled,
  .workspace-panel__button[aria-disabled="true"] {
    opacity: 0.45;
    pointer-events: none;
  }

  .component-slide-list {
    display: grid;
    gap: 10px;
    margin-top: 14px;
  }

  .component-slide-card {
    display: grid;
    grid-template-columns: auto auto minmax(0, 1fr) auto;
    gap: 14px;
    align-items: center;
    padding: 14px 16px;
    border: 1px solid #dde3ec;
    border-radius: 14px;
    background: #fafcff;
  }

  .component-slide-card.is-dragging {
    opacity: 0.5;
  }

  .component-slide-card__handle {
    width: 34px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px dashed #c9d6e6;
    border-radius: 10px;
    background: #f6f9fd;
    color: #7a8aa2;
    font: inherit;
    font-size: 16px;
    cursor: grab;
  }

  .component-slide-card__handle:active {
    cursor: grabbing;
  }

  .component-slide-card__index {
    width: 34px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: #eef3fb;
    color: #30507c;
    font-size: 12px;
    font-weight: 800;
  }

  .component-slide-card__body {
    display: grid;
    gap: 6px;
    min-width: 0;
  }

  .component-slide-card__title-input,
  .component-slide-card__help-input {
    width: 100%;
    border: 0;
    border-radius: 10px;
    background: transparent;
    color: inherit;
    font: inherit;
    padding: 4px 0;
    outline: none;
  }

  .component-slide-card__title-input {
    font-size: 17px;
    color: #183b68;
    font-weight: 800;
  }

  .component-slide-card__help-input {
    color: #5f7da6;
    font-size: 13px;
    line-height: 1.5;
  }

  .component-slide-card__title-input::placeholder,
  .component-slide-card__help-input::placeholder {
    color: #95a1b2;
  }

  .component-slide-card__title-input.is-plain:hover,
  .component-slide-card__help-input.is-plain:hover,
  .component-slide-card__title-input.is-plain:focus,
  .component-slide-card__help-input.is-plain:focus {
    background: #ffffff;
