---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sessions } from "../../data/schedule";

export function getStaticPaths() {
  return sessions.map((session) => ({
    params: { slug: session.slug },
    props: { session },
  }));
}

const { session } = Astro.props;
---

<BaseLayout title={session.label}>
  <section class="panel">
    <h1>{session.label}</h1>
    <p>{session.summary}</p>
  </section>

  <section class="panel">
    <h2>수업 정보</h2>
    <div class="list">
      <div class="item">
        <strong>수업</strong>
        <span>{session.course}</span>
      </div>
      <div class="item">
        <strong>날짜</strong>
        <span>{session.date}</span>
      </div>
      <div class="item">
        <strong>시간</strong>
        <span>{session.time}</span>
      </div>
      <div class="item">
        <strong>상태</strong>
        <span>{session.status}</span>
      </div>
    </div>
  </section>

  <section class="panel">
    <h2>연결</h2>
    <div class="list">
      {session.isFirstLesson ? (
        <a class="item" href={`${import.meta.env.BASE_URL}260314_%EC%B2%AB%EC%88%98%EC%97%85/materials/`}>
          <strong>첫 수업 자료 열기</strong>
          <span>현재 이 수업 항목은 첫 수업 페이지와 연결되어 있습니다.</span>
        </a>
      ) : (
        <div class="item">
          <strong>자료 연결 대기</strong>
          <span>이 항목에는 아직 실제 수업 자료를 연결하지 않았습니다.</span>
        </div>
      )}

      <a class="item" href={`${import.meta.env.BASE_URL}classes/`}>
        <strong>강의 목록으로 돌아가기</strong>
        <span>전체 강의 항목 페이지로 이동합니다.</span>
      </a>
    </div>
  </section>
</BaseLayout>

