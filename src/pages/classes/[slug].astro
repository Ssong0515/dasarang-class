---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sessions } from "../../data/schedule";
import { getSlidesForSession, loadComponentSlides } from "../../lib/lesson-materials";
import type { SlideDocument } from "../../lib/lesson-materials";
import { getNote } from "../../lib/notes";
import { withBase } from "../../lib/site";

export const prerender = false;

const slug = Astro.params.slug ?? "";
const session = sessions.find((entry) => entry.slug === slug);

if (!session) {
  Astro.response.status = 404;
}

const note = session ? await getNote(slug, Astro.locals) : undefined;
const material = session
  ? await getSlidesForSession(slug)
  : { slides: [], slidesDir: undefined, source: "none" as const };
const slides = material.slides ?? [];
const initialBadgeLabel = slides[0]?.helpLabel || "Slide Lesson";
const isComponentSlideDeck = material.source === "component";
type ComponentSlide = Extract<SlideDocument, { kind: "component" }>;
const componentSlides = slides.filter((slide): slide is ComponentSlide => slide.kind === "component");
const loadedComponentSlides = isComponentSlideDeck ? await loadComponentSlides(slug) : [];
---

<BaseLayout title={session ? session.label : "수업을 찾을 수 없습니다"}>
  {
    session ? (
      <>
        <section class="panel lesson-header">
          <div class="lesson-header__title">
            <div class="lesson-header__heading">
              <h1>{session.label}</h1>
              <span class="lesson-header__schedule">{session.date} / {session.time}</span>
            </div>
            <p>{session.summary}</p>
          </div>
        </section>

        <section class="panel">
          <details class="note-panel" data-note-panel>
            <summary class="note-panel__summary">
              <div>
                <h2>수업 메모</h2>
                <p class="section-copy">필요할 때만 열어서 적고, 저장하면 다시 접힙니다.</p>
              </div>
              <div class="note-panel__meta">
                {
                  note?.updatedAt ? (
                    <span class="section-meta">
                      마지막 저장 {new Intl.DateTimeFormat("ko-KR", {
                        dateStyle: "medium",
                        timeStyle: "short",
                        timeZone: "Asia/Seoul",
                      }).format(new Date(note.updatedAt))}
                    </span>
                  ) : (
                    <span class="section-meta">아직 저장된 메모 없음</span>
                  )
                }
                <span class="note-panel__arrow" aria-hidden="true"></span>
              </div>
            </summary>

            <div class="note-panel__body">
              <form class="note-form" method="POST" action={withBase(`/api/notes/${slug}/`)} data-note-form>
                <textarea
                  class="note-textarea"
                  name="content"
                  rows={14}
                  placeholder="오늘 수업 흐름, 주제, 아이디어, 준비할 것들을 자유롭게 적어두세요."
                >{note?.content ?? ""}</textarea>
                <div class="note-actions">
                  <p class="save-notice" data-note-status aria-live="polite"></p>
                  <button class="note-save" type="submit">저장</button>
                </div>
              </form>
            </div>
          </details>
        </section>

        {isComponentSlideDeck && componentSlides.length > 0 ? (
          <section class="panel material-panel">
            <div class="section-head">
              <h2>슬라이드</h2>
              <span class="section-badge">{componentSlides.length}장</span>
            </div>

            <p class="section-copy">
              `수업 시작`은 발표용 전체 슬라이드를 열고 바로 전체화면으로 들어갑니다. 아래 목록에서 각 슬라이드를 누르면 장별 편집 화면이 열립니다.
            </p>

            <div class="workspace-panel">
              <div class="workspace-panel__meta">
                <strong>수업과 편집을 분리했습니다</strong>
                <span>수업할 때는 `수업 시작`, 수정할 때는 아래 슬라이드 목록에서 원하는 장을 누르면 됩니다.</span>
              </div>
              <button class="workspace-panel__button" type="button" data-open-class-player>수업 시작</button>
            </div>

            <div class="component-slide-list">
              {componentSlides.map((slide, index) => (
                <a class="component-slide-card" href={withBase(slide.previewPath)}>
                  <span class="component-slide-card__index">{String(index + 1).padStart(2, "0")}</span>
                  <div class="component-slide-card__body">
                    <strong>{slide.title}</strong>
                    <span>{slide.helpLabel || "슬라이드 편집 화면 열기"}</span>
                  </div>
                  <span class="component-slide-card__action">편집</span>
                </a>
              ))}
            </div>
          </section>
        ) : (
          <section class="panel empty-panel">
            <h2>자료 연결 대기</h2>
            <p>이 수업에는 아직 사용할 컴포넌트 슬라이드가 없습니다.</p>
            <a class="empty-panel__link" href={withBase("/classes/")}>강의 목록으로 돌아가기</a>
          </section>
        )}

        {
          isComponentSlideDeck && loadedComponentSlides.length > 0 ? (
            <div class="class-player-modal" hidden data-class-player-modal>
              <div class="class-player" data-slide-player data-fullscreen-shell>
                <header class="class-player__topbar">
                  <div class="class-player__meta">
                    <span class="class-player__eyebrow">수업 모드</span>
                    <strong class="class-player__title" data-slide-current-title>
                      {loadedComponentSlides[0]?.meta.title ?? session.label}
                    </strong>
                    <span class="class-player__subtitle">
                      {session.label} · <span data-page-info>1 / {loadedComponentSlides.length}</span>
                    </span>
                  </div>
                  <div class="class-player__actions">
                    <span class="class-player__badge" data-slide-badge>{initialBadgeLabel}</span>
                    <button class="class-player__button" type="button" data-fullscreen-btn>전체화면</button>
                    <button class="class-player__button class-player__button--secondary" type="button" data-close-class-player>
                      닫기
                    </button>
                  </div>
                </header>

                <main class="class-player__stage">
                  <div class="class-player__viewport">
                    <div class="class-player__track" data-slide-track>
                      {loadedComponentSlides.map((slide, index) => {
                        const SlideComponent = slide.component;

                        return (
                          <section
                            class="class-player__slide"
                            data-slide-index={index}
                            data-slide-badge-label={slide.meta.helpLabel || ""}
                            data-slide-title={slide.meta.title}
                            aria-label={`슬라이드 ${index + 1}`}
                          >
                            <div class="class-player__canvas">
                              <div class="class-player__slide-meta">
                                <span>{String(slide.meta.order).padStart(2, "0")}</span>
                                <span>{slide.meta.fileName}</span>
                              </div>
                              <SlideComponent />
                            </div>
                          </section>
                        );
                      })}
                    </div>
                  </div>
                </main>

                <nav class="class-player__controls">
                  <button class="class-player__button" type="button" data-slide-prev>이전</button>
                  <div class="class-player__controls-center">
                    <div class="class-player__dots" data-slide-dots></div>
                  </div>
                  <button class="class-player__button" type="button" data-slide-next>다음</button>
                </nav>
              </div>
            </div>
          ) : null
        }
      </>
    ) : (
      <section class="panel">
        <h1>수업을 찾을 수 없습니다</h1>
        <p>요청한 수업 슬러그에 해당하는 일정이 없습니다.</p>
      </section>
    )
  }
</BaseLayout>

<script>
  const notePanel = document.querySelector("[data-note-panel]");
  const noteForm = document.querySelector("[data-note-form]");
  const noteStatus = document.querySelector("[data-note-status]");
  const classPlayerModal = document.querySelector("[data-class-player-modal]");
  const classPlayerShell = classPlayerModal?.querySelector("[data-fullscreen-shell]");
  const openClassPlayerButton = document.querySelector("[data-open-class-player]");
  const closeClassPlayerButton = classPlayerModal?.querySelector("[data-close-class-player]");

  if (notePanel instanceof HTMLDetailsElement && noteForm instanceof HTMLFormElement) {
    noteForm.addEventListener("submit", async (event) => {
      event.preventDefault();

      const submitButton = noteForm.querySelector('button[type="submit"]');
      if (!(submitButton instanceof HTMLButtonElement)) return;

      submitButton.disabled = true;
      if (noteStatus instanceof HTMLElement) {
        noteStatus.textContent = "저장 중...";
      }

      try {
        const response = await fetch(noteForm.action, {
          method: "POST",
          body: new FormData(noteForm),
          headers: {
            Accept: "application/json",
          },
        });

        if (!response.ok) {
          throw new Error("save_failed");
        }

        notePanel.open = false;
        if (noteStatus instanceof HTMLElement) {
          noteStatus.textContent = "저장했습니다.";
        }
      } catch {
        if (noteStatus instanceof HTMLElement) {
          noteStatus.textContent = "저장에 실패했습니다.";
        }
      } finally {
        submitButton.disabled = false;
      }
    });
  }

  const openClassPlayer = async () => {
    if (!(classPlayerModal instanceof HTMLElement) || !(classPlayerShell instanceof HTMLElement)) {
      return;
    }

    classPlayerModal.hidden = false;
    document.body.classList.add("class-player-open");

    try {
      await classPlayerShell.requestFullscreen();
    } catch {
      // Fullscreen can fail if the browser blocks it; the overlay remains open.
    }
  };

  const closeClassPlayer = async () => {
    if (!(classPlayerModal instanceof HTMLElement)) {
      return;
    }

    if (document.fullscreenElement) {
      await document.exitFullscreen();
    }

    classPlayerModal.hidden = true;
    document.body.classList.remove("class-player-open");
  };

  openClassPlayerButton?.addEventListener("click", () => {
    void openClassPlayer();
  });

  closeClassPlayerButton?.addEventListener("click", () => {
    void closeClassPlayer();
  });

  const players = document.querySelectorAll("[data-slide-player]");

  players.forEach((player) => {
    const track = player.querySelector("[data-slide-track]");
    const slides = Array.from(player.querySelectorAll("[data-slide-index]"));
    const dots = player.querySelector("[data-slide-dots]");
    const prevButton = player.querySelector("[data-slide-prev]");
    const nextButton = player.querySelector("[data-slide-next]");
    const pageInfo = player.querySelector("[data-page-info]");
    const fullscreenButton = player.querySelector("[data-fullscreen-btn]");
    const badge = player.querySelector("[data-slide-badge]");
    const currentTitle = player.querySelector("[data-slide-current-title]");
    const fullscreenShell = player.closest("[data-fullscreen-shell]");
    let current = 0;

    const goTo = (index) => {
      current = Math.max(0, Math.min(index, slides.length - 1));
      if (track instanceof HTMLElement) {
        track.style.transform = `translateX(-${current * 100}%)`;
      }
      dots?.querySelectorAll(".deck-dot-btn").forEach((dot, dotIndex) => {
        dot.classList.toggle("active", dotIndex === current);
      });
      if (prevButton instanceof HTMLButtonElement) prevButton.disabled = current === 0;
      if (nextButton instanceof HTMLButtonElement) nextButton.disabled = current === slides.length - 1;
      if (pageInfo) pageInfo.textContent = `${current + 1} / ${slides.length}`;
      if (badge) badge.textContent = slides[current]?.dataset.slideBadgeLabel || "Slide Lesson";
      if (currentTitle) currentTitle.textContent = slides[current]?.dataset.slideTitle || "";
    };

    if (dots instanceof HTMLElement) {
      dots.innerHTML = "";
      slides.forEach((_, index) => {
        const button = document.createElement("button");
        button.type = "button";
        button.className = "deck-dot-btn";
        button.addEventListener("click", () => goTo(index));
        dots.appendChild(button);
      });
    }

    prevButton?.addEventListener("click", () => goTo(current - 1));
    nextButton?.addEventListener("click", () => goTo(current + 1));

    fullscreenButton?.addEventListener("click", async () => {
      const target = fullscreenShell instanceof HTMLElement ? fullscreenShell : player;

      if (document.fullscreenElement === target) {
        await document.exitFullscreen();
      } else if (target instanceof HTMLElement) {
        await target.requestFullscreen();
      }
    });

    goTo(0);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key !== "Escape") return;
    if (!(classPlayerModal instanceof HTMLElement) || classPlayerModal.hidden) return;
    if (document.fullscreenElement) return;
    void closeClassPlayer();
  });
</script>

<style>
  .lesson-header { background: linear-gradient(180deg, #ffffff 0%, #fcfaf7 100%); }
  .lesson-header__heading { display: flex; gap: 12px; align-items: baseline; flex-wrap: wrap; }
  .lesson-header__schedule { color: #7d7568; font-size: 14px; font-weight: 700; }
  .section-head { display: flex; justify-content: space-between; gap: 14px; align-items: center; margin-bottom: 12px; }
  .section-copy { margin: 6px 0 0; color: #7b7b7b; font-size: 13px; }
  .section-meta { color: #7b7b7b; font-size: 12px; font-weight: 700; }
  .section-badge { padding: 8px 12px; border-radius: 999px; background: #eef6ff; color: #24538a; font-size: 12px; font-weight: 800; }
  .workspace-panel {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: center;
    margin-top: 14px;
    padding: 18px;
    border: 1px solid #d8e2ef;
    border-radius: 16px;
    background: linear-gradient(180deg, #f7fbff 0%, #eef5fc 100%);
  }
  .workspace-panel__meta {
    display: grid;
    gap: 6px;
  }
  .workspace-panel__meta strong {
    color: #25466f;
    font-size: 15px;
  }
  .workspace-panel__meta span {
    color: #5f7289;
    font-size: 13px;
    line-height: 1.65;
  }
  .workspace-panel__button {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 16px;
    border-radius: 999px;
    background: #1c2434;
    color: #fff;
    text-decoration: none;
    font-size: 13px;
    font-weight: 800;
    border: 0;
    cursor: pointer;
  }
  .component-slide-list {
    display: grid;
    gap: 10px;
    margin-top: 14px;
  }
  .component-slide-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 14px;
    align-items: center;
    padding: 14px 16px;
    border: 1px solid #dde3ec;
    border-radius: 14px;
    background: #fafcff;
    color: inherit;
    text-decoration: none;
  }
  .component-slide-card__index {
    width: 34px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: #eef3fb;
    color: #30507c;
    font-size: 12px;
    font-weight: 800;
  }
  .component-slide-card__body {
    display: grid;
    gap: 4px;
    min-width: 0;
  }
  .component-slide-card__body strong {
    font-size: 15px;
    color: #2f3949;
  }
  .component-slide-card__body span {
    color: #758196;
    font-size: 12px;
    line-height: 1.5;
  }
  .component-slide-card__action {
    color: #24538a;
    font-size: 12px;
    font-weight: 800;
  }
  .note-panel {
    border: 1px solid #dfdfdf;
    border-radius: 16px;
    background: #fcfcfc;
  }
  .note-panel[open] {
    background: #ffffff;
  }
  .note-panel__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 20px;
    cursor: pointer;
    list-style: none;
  }
  .note-panel__summary::-webkit-details-marker {
    display: none;
  }
  .note-panel__summary h2 {
    margin: 0;
  }
  .note-panel__meta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .note-panel__arrow::before {
    content: "▸";
    color: #6f6f6f;
    font-size: 14px;
  }
  .note-panel[open] .note-panel__arrow::before {
    content: "▾";
  }
  .note-panel__body {
    padding: 0 20px 20px;
    border-top: 1px solid #ececec;
  }
  .note-form { display: grid; gap: 12px; padding-top: 16px; }
  .note-textarea { width: 100%; min-height: 320px; padding: 16px; border: 1px solid #d6d6d6; border-radius: 14px; background: #fcfcfc; color: #3f3f3f; font: inherit; line-height: 1.7; resize: vertical; }
  .note-actions { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .save-notice { margin: 0; color: #1f6f43; font-size: 13px; font-weight: 700; }
  .note-save { padding: 10px 18px; border: 0; border-radius: 12px; background: #1c2434; color: #fff; font: inherit; font-weight: 700; cursor: pointer; }
  .note-save:disabled { opacity: 0.6; cursor: wait; }
  .deck {
    --deck-surface: rgba(255, 251, 245, 0.96);
    --deck-line: #e4d7c6;
    --deck-frame-max: min(1120px, calc(100vw - 96px));
    --deck-frame-height: clamp(260px, calc(var(--deck-frame-max) * 9 / 16), 72vh);
    display: grid;
    gap: 14px;
  }
  .deck-topbar, .deck-controls, .deck-slide__inner { background: var(--deck-surface); border: 2px solid var(--deck-line); border-radius: 24px; }
  .deck-topbar, .deck-controls { padding: 12px 16px; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .deck-brand, .deck-actions { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .deck-badge, .deck-top-btn, .deck-nav-btn { padding: 8px 12px; border-radius: 16px; font: inherit; }
  .deck-top-btn, .deck-nav-btn, .empty-panel__link { background: #1c2434; color: #fff; border: 0; text-decoration: none; cursor: pointer; }
  .deck-nav-btn { width: min(100%, 104px); max-width: 104px; text-align: center; }
  .deck-viewport {
    overflow: hidden;
    border-radius: 34px;
    width: min(100%, var(--deck-frame-max));
    margin: 0 auto;
  }
  .deck-track { display: flex; transition: transform 0.42s cubic-bezier(0.22, 1, 0.36, 1); }
  .deck-slide { flex: 0 0 100%; }
  .deck-slide__inner { overflow: hidden; }
  .deck-slide__meta { display: grid; grid-template-columns: auto 1fr auto; gap: 12px; padding: 12px 16px; border-bottom: 1px solid #ebebeb; background: #f8f8f8; color: #6f6f6f; font-size: 13px; }
  .deck-slide__stage {
    position: relative;
    display: grid;
    place-items: center;
    width: 100%;
    height: var(--deck-frame-height);
    overflow: hidden;
    background: #e8edf3;
  }
  .deck-slide__canvas {
    width: 1600px;
    height: 900px;
    transform-origin: center center;
    will-change: transform;
  }
  .deck-slide__canvas--component {
    overflow: hidden;
    background: #fff;
  }
  .deck-slide__frame {
    display: block;
    width: 1600px;
    height: 900px;
    border: 0;
    background: #fff;
  }
  .deck-controls { display: grid; grid-template-columns: auto 1fr auto; align-items: center; }
  .deck-controls__center {
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .deck-dots { display: flex; justify-content: center; gap: 8px; }
  .deck-dot-btn { width: 14px; height: 14px; border: 0; border-radius: 999px; background: #d3d9e4; cursor: pointer; }
  .deck-dot-btn.active { width: 40px; background: #ff845d; }
  .deck-page { color: #6f6f6f; font-size: 13px; font-weight: 700; text-align: center; }
  .empty-panel { text-align: center; }
  .class-player-modal {
    position: fixed;
    inset: 0;
    z-index: 2000;
    padding: 20px;
    background: rgba(17, 24, 39, 0.7);
    backdrop-filter: blur(12px);
  }
  .class-player-shell {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
  }
  .class-player-deck {
    width: min(100%, 1480px);
  }
  .class-player-deck__topbar .deck-actions {
    justify-content: flex-end;
  }
  .deck-top-btn--secondary {
    background: #fff;
    color: #1c2434;
    border: 1px solid #cfd7e4;
  }

  .deck:fullscreen {
    --deck-frame-max: min(1440px, calc(100vw - 48px));
    --deck-frame-height: min(calc(100vh - 220px), calc(var(--deck-frame-max) * 9 / 16));
    height: 100vh;
    grid-template-rows: auto 1fr auto;
    align-content: stretch;
    justify-items: center;
    padding: 20px;
    background: linear-gradient(180deg, #f5ede2 0%, #efe3d1 100%);
  }

  .deck:fullscreen .deck-viewport {
    width: min(100%, var(--deck-frame-max));
    margin: 0 auto;
    align-self: center;
  }

  .deck:fullscreen .deck-topbar,
  .deck:fullscreen .deck-controls {
    width: min(100%, var(--deck-frame-max));
    padding: 10px 14px;
  }

  @media (max-width: 900px) {
    .deck {
      --deck-frame-max: calc(100vw - 64px);
      --deck-frame-height: clamp(220px, calc(var(--deck-frame-max) * 9 / 16), 62vh);
    }
    .section-head,
    .note-panel__summary,
    .note-actions,
    .deck-topbar,
    .workspace-panel {
      align-items: flex-start;
      flex-direction: column;
    }
    .deck-dots {
      justify-content: center;
      flex-wrap: wrap;
    }
    .deck-slide__meta {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .deck {
      --deck-frame-max: calc(100vw - 48px);
      --deck-frame-height: clamp(190px, calc(var(--deck-frame-max) * 9 / 16), 52vh);
    }
    .deck-topbar,
    .deck-controls,
    .deck-slide__meta {
      padding: 12px;
    }
    .component-slide-card {
      grid-template-columns: auto 1fr;
    }
    .component-slide-card__action {
      grid-column: 2;
    }
    .deck-topbar,
    .deck-controls,
    .deck-slide__inner {
      border-radius: 18px;
    }
    .deck-viewport {
      border-radius: 22px;
    }
    .class-player-modal {
      padding: 12px;
    }
    .deck-badge,
    .deck-top-btn,
    .deck-nav-btn {
      width: min(100%, 104px);
      justify-content: center;
    }
  }

  @media (max-height: 760px) {
    .deck {
      --deck-frame-height: min(50vh, calc(var(--deck-frame-max) * 9 / 16));
    }
  }

  @media (max-height: 760px) and (min-width: 901px) {
    .deck:fullscreen {
