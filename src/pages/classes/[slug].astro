---
import { getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sessions } from "../../data/schedule";
import { getSlidesForSession } from "../../lib/lesson-materials";
import { withBase } from "../../lib/site";

export const prerender = false;

const slug = Astro.params.slug ?? "";
const session = sessions.find((entry) => entry.slug === slug);

if (!session) {
  Astro.response.status = 404;
}

const noteEntry = session ? await getEntry("classNotes", slug) : undefined;
const note = noteEntry ? await noteEntry.render() : undefined;
const material = session ? getSlidesForSession(slug) : { slides: [], slidesDir: undefined };
const slides = material.slides ?? [];
const slideFileNames = slides.map((slide) => slide.fileName);
const slidesDir = material.slidesDir ?? "해당 날짜 수업 폴더 없음";
const initialBadgeLabel = slides[0]?.helpLabel || "Slide Lesson";
---

<BaseLayout title={session ? session.label : "수업을 찾을 수 없습니다"}>
  {
    session ? (
      <>
        <section class="panel lesson-header">
          <div class="lesson-header__title">
            <div class="lesson-header__heading">
              <h1>{session.label}</h1>
              <span class="lesson-header__schedule">{session.date} / {session.time}</span>
            </div>
            <p>{session.summary}</p>
            <p class="folder-path">
              <span>폴더</span>
              <strong>{slidesDir}</strong>
              <button
                class="folder-copy"
                type="button"
                data-copy-path={material.slidesDir ?? ""}
                aria-label="폴더 경로 복사"
                title="폴더 경로 복사"
                disabled={!material.slidesDir}
              >
                복사
              </button>
            </p>
          </div>
        </section>

        <section class="panel">
          <div class="section-head">
            <h2>Slides HTML</h2>
            <span class="section-badge">{slideFileNames.length}개</span>
          </div>

          {slideFileNames.length > 0 ? (
            <ol class="file-list">
              {slideFileNames.map((fileName, index) => (
                <li class="file-row">
                  <span class="file-row__index">{String(index + 1).padStart(2, "0")}</span>
                  <strong>{fileName}</strong>
                </li>
              ))}
            </ol>
          ) : (
            <div class="empty-note">
              <strong>슬라이드 파일 없음</strong>
              <span>현재 `slides` 폴더 안에 표시할 HTML 파일이 없습니다.</span>
            </div>
          )}
        </section>

        <section class="panel">
          <h2>수업 정보</h2>
          <div class="list">
            <div class="item">
              <strong>반</strong>
              <span>{session.course}</span>
            </div>
            <div class="item">
              <strong>날짜</strong>
              <span>{session.date}</span>
            </div>
            <div class="item">
              <strong>시간</strong>
              <span>{session.time}</span>
            </div>
            <div class="item">
              <strong>상태</strong>
              <span>{session.status}</span>
            </div>
          </div>
        </section>

        <section class="panel">
          <div class="section-head">
            <h2>수업 메모</h2>
          </div>
          {
            note ? (
              <article class="note-body">
                <note.Content />
              </article>
            ) : (
              <div class="empty-note">
                <strong>메모 파일 없음</strong>
                <span>`src/content/classNotes/{slug}.md` 파일을 추가하면 여기에서 바로 보입니다.</span>
              </div>
            )
          }
        </section>

        {slides.length > 0 ? (
          <section class="panel material-panel">
            <div class="section-head">
              <h2>수업 슬라이드</h2>
              <span class="section-badge">{slides.length}장</span>
            </div>

            <div class="deck" data-slide-player>
              <header class="deck-topbar">
                <div class="deck-brand">
                  <strong>Dasarang Class</strong>
                  <span>/</span>
                  <span>{session.label}</span>
                </div>
                <div class="deck-actions">
                  <div class="deck-badge" data-slide-badge>{initialBadgeLabel}</div>
                  <button class="deck-top-btn" type="button" data-fullscreen-btn>전체보기</button>
                </div>
              </header>

              <main class="deck-viewport">
                <div class="deck-track" data-slide-track>
                  {slides.map((slide, index) => (
                    <section
                      class="deck-slide"
                      data-slide-index={index}
                      data-slide-badge-label={slide.helpLabel || ""}
                      aria-label={`슬라이드 ${index + 1}`}
                    >
                      <div class="deck-slide__inner">
                        <div class="deck-slide__meta">
                          <span>{String(slide.order).padStart(2, "0")}</span>
                          <strong>{slide.title}</strong>
                          <span>{slide.fileName}</span>
                        </div>
                        <iframe
                          class="deck-slide__frame"
                          srcdoc={slide.html}
                          title={slide.title}
                          loading="lazy"
                          sandbox="allow-same-origin allow-scripts"
                        />
                      </div>
                    </section>
                  ))}
                </div>
              </main>

              <nav class="deck-controls">
                <button class="deck-nav-btn" type="button" data-slide-prev>이전</button>
                <div class="deck-dots" data-slide-dots></div>
                <div class="deck-controls__end">
                  <div class="deck-page" data-page-info>1 / {slides.length}</div>
                  <button class="deck-nav-btn" type="button" data-slide-next>다음</button>
                </div>
              </nav>
            </div>
          </section>
        ) : (
          <section class="panel empty-panel">
            <h2>자료 연결 대기</h2>
            <p>이 수업에는 아직 `slides/*.html` 파일이 없습니다.</p>
            <a class="empty-panel__link" href={withBase("/classes/")}>강의 목록으로 돌아가기</a>
          </section>
        )}
      </>
    ) : (
      <section class="panel">
        <h1>수업을 찾을 수 없습니다</h1>
        <p>요청한 수업 슬러그에 해당하는 일정이 없습니다.</p>
      </section>
    )
  }
</BaseLayout>

<script>
  const copyButtons = document.querySelectorAll("[data-copy-path]");

  copyButtons.forEach((button) => {
    if (!(button instanceof HTMLButtonElement)) return;
    button.addEventListener("click", async () => {
      const path = button.dataset.copyPath;
      if (!path) return;
      await navigator.clipboard.writeText(path);
      button.textContent = "복사됨";
      window.setTimeout(() => {
        button.textContent = "복사";
      }, 1200);
    });
  });

  const players = document.querySelectorAll("[data-slide-player]");

  players.forEach((player) => {
    const track = player.querySelector("[data-slide-track]");
    const slides = Array.from(player.querySelectorAll("[data-slide-index]"));
    const dots = player.querySelector("[data-slide-dots]");
    const prevButton = player.querySelector("[data-slide-prev]");
    const nextButton = player.querySelector("[data-slide-next]");
    const pageInfo = player.querySelector("[data-page-info]");
    const fullscreenButton = player.querySelector("[data-fullscreen-btn]");
    const badge = player.querySelector("[data-slide-badge]");
    let current = 0;

    const goTo = (index) => {
      current = Math.max(0, Math.min(index, slides.length - 1));
      if (track instanceof HTMLElement) {
        track.style.transform = `translateX(-${current * 100}%)`;
      }
      dots?.querySelectorAll(".deck-dot-btn").forEach((dot, dotIndex) => {
        dot.classList.toggle("active", dotIndex === current);
      });
      if (prevButton instanceof HTMLButtonElement) prevButton.disabled = current === 0;
      if (nextButton instanceof HTMLButtonElement) nextButton.disabled = current === slides.length - 1;
      if (pageInfo) pageInfo.textContent = `${current + 1} / ${slides.length}`;
      if (badge) badge.textContent = slides[current]?.dataset.slideBadgeLabel || "Slide Lesson";
    };

    if (dots instanceof HTMLElement) {
      dots.innerHTML = "";
      slides.forEach((_, index) => {
        const button = document.createElement("button");
        button.type = "button";
        button.className = "deck-dot-btn";
        button.addEventListener("click", () => goTo(index));
        dots.appendChild(button);
      });
    }

    prevButton?.addEventListener("click", () => goTo(current - 1));
    nextButton?.addEventListener("click", () => goTo(current + 1));

    fullscreenButton?.addEventListener("click", async () => {
      if (document.fullscreenElement === player) {
        await document.exitFullscreen();
      } else if (player instanceof HTMLElement) {
        await player.requestFullscreen();
      }
    });

    goTo(0);
  });
</script>

<style>
  .lesson-header { background: linear-gradient(180deg, #ffffff 0%, #fcfaf7 100%); }
  .lesson-header__heading { display: flex; gap: 12px; align-items: baseline; }
  .lesson-header__schedule { color: #7d7568; font-size: 14px; font-weight: 700; }
  .folder-path { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
  .folder-copy { padding: 6px 10px; border: 1px solid #ddd4c7; border-radius: 8px; background: #f7f3ed; }
  .section-head { display: flex; justify-content: space-between; gap: 14px; align-items: center; margin-bottom: 12px; }
  .section-badge { padding: 8px 12px; border-radius: 999px; background: #eef6ff; color: #24538a; font-size: 12px; font-weight: 800; }
  .file-list { margin: 0; padding: 0; list-style: none; display: flex; flex-wrap: wrap; gap: 8px; }
  .file-row { display: inline-flex; gap: 10px; padding: 8px 12px; border: 1px solid #ebe5dc; border-radius: 999px; background: #faf8f4; }
  .file-row__index { min-width: 26px; height: 26px; display: inline-flex; align-items: center; justify-content: center; border-radius: 999px; background: #f2eee8; font-size: 11px; font-weight: 800; }
  .note-body { padding: 18px; border: 1px solid #d2d2d2; border-radius: 12px; background: #fcfcfc; line-height: 1.8; }
  .empty-note { padding: 18px; border: 1px dashed #c8b18f; border-radius: 12px; background: #fffaf3; color: #73573a; line-height: 1.7; }
  .empty-note strong, .empty-note span { display: block; }
  .empty-note strong { margin-bottom: 6px; }
  .deck { display: grid; gap: 14px; }
  .deck-topbar, .deck-controls, .deck-slide__inner { background: rgba(255, 251, 245, 0.96); border: 2px solid #e4d7c6; border-radius: 24px; }
  .deck-topbar, .deck-controls { padding: 12px 16px; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .deck-actions, .deck-controls__end { display: flex; align-items: center; gap: 12px; }
  .deck-badge, .deck-top-btn, .deck-nav-btn { padding: 8px 12px; border-radius: 16px; }
  .deck-top-btn, .deck-nav-btn, .empty-panel__link { background: #1c2434; color: #fff; border: 0; text-decoration: none; cursor: pointer; }
  .deck-viewport { overflow: hidden; border-radius: 34px; }
  .deck-track { display: flex; transition: transform 0.42s cubic-bezier(0.22, 1, 0.36, 1); }
  .deck-slide { flex: 0 0 100%; }
  .deck-slide__inner { overflow: hidden; }
  .deck-slide__meta { display: grid; grid-template-columns: auto 1fr auto; gap: 12px; padding: 12px 16px; border-bottom: 1px solid #ebebeb; background: #f8f8f8; color: #6f6f6f; font-size: 13px; }
  .deck-slide__frame { display: block; width: 100%; min-height: 560px; aspect-ratio: 16 / 9; border: 0; background: #fff; }
  .deck-controls { display: grid; grid-template-columns: auto 1fr auto; }
  .deck-dots { display: flex; justify-content: center; gap: 8px; }
  .deck-dot-btn { width: 14px; height: 14px; border: 0; border-radius: 999px; background: #d3d9e4; cursor: pointer; }
  .deck-dot-btn.active { width: 40px; background: #ff845d; }
  .empty-panel { text-align: center; }
</style>
