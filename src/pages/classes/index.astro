---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { monthGroups } from "../../data/schedule";
---

<BaseLayout title="2026년 1학기 강의 목록">
  <section class="panel">
    <h1>2026년 1학기 강의 목록</h1>
    <p>강의 항목은 시간표 기준으로 자동 생성합니다. 월별로 보고, 그 아래에서 반이나 과정 단위로 정리해서 찾을 수 있습니다.</p>
  </section>

  {monthGroups.map(({ month, courses }) => (
    <section class="panel month" id={`month-${month.replace("월", "")}`}>
      <h2>{month}</h2>
      <div class="course-list">
        {courses.map(({ course, sessions }) => (
          <div class="course">
            <h3>{course}</h3>
            <div class="rows">
              {sessions.map((session) => (
                <a class="row" href={`${import.meta.env.BASE_URL}classes/${session.slug}/`}>
                  <strong>{session.label}</strong>
                  <span>{session.date}</span>
                  <span>{session.time}</span>
                  <span class:list={["status", session.isFirstLesson && "is-main"]}>{session.status}</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>

<style>
  .month {
    margin-bottom: 18px;
  }

  .month h2 {
    font-size: 20px;
    margin-bottom: 12px;
  }

  .course-list {
    display: grid;
    gap: 16px;
  }

  .course {
    padding: 14px;
    border: 1px solid #dcdcdc;
    border-radius: 10px;
    background: #fcfcfc;
  }

  .course h3 {
    margin: 0 0 10px;
    font-size: 16px;
    font-weight: 700;
    color: #505050;
  }

  .rows {
    display: grid;
    gap: 8px;
  }

  .row {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr 1fr 0.8fr;
    gap: 12px;
    align-items: center;
    padding: 14px 16px;
    border: 1px solid #d2d2d2;
    border-radius: 10px;
    background: #fafafa;
    color: inherit;
    text-decoration: none;
  }

  .row strong {
    font-size: 14px;
    font-weight: 700;
  }

  .row span {
    color: #7b7b7b;
    font-size: 14px;
  }

  .status.is-main {
    color: #6d5b43;
    font-weight: 700;
  }

  @media (max-width: 1100px) {
    .row {
      grid-template-columns: 1fr;
    }
  }
</style>
