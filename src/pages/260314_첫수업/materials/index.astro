---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { withBase } from "../../../lib/site";
import lessonHtml from "../../../../260314_첫수업/materials/index.html?raw";

const styleMatch = lessonHtml.match(/<style>([\s\S]*?)<\/style>/i);
const bodyMatch = lessonHtml.match(/<body[^>]*>([\s\S]*?)<\/body>/i);

const lessonStyle = styleMatch ? styleMatch[1] : "";
let lessonBody = bodyMatch ? bodyMatch[1] : lessonHtml;

lessonBody = lessonBody
  .replace(/<script[^>]*shared\/sidebar\.js[^>]*><\/script>/gi, "")
  .replace(/<link[^>]*shared\/sidebar\.css[^>]*>/gi, "")
  .replace(/href="\.\.\/\.\.\//gi, `href="${withBase("/")}"`);
---

<BaseLayout title="260314 첫수업">
  <style is:global set:html={lessonStyle} />
  <Fragment set:html={lessonBody} />
</BaseLayout>
