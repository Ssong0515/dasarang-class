{
  "entities": {
    "User": {
      "title": "User",
      "description": "Admin or teacher profile",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "teacher"] }
      },
      "required": ["email"]
    },
    "Classroom": {
      "title": "Classroom",
      "description": "Classroom configuration and assigned content",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerUid": { "type": "string" },
        "students": {
          "type": "array",
          "items": { "type": "object" }
        },
        "assignedContentIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "isOpen": { "type": "boolean" },
        "order": { "type": "number" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerUid"]
    },
    "Student": {
      "title": "Student",
      "description": "Global student master record",
      "type": "object",
      "properties": {
        "ownerUid": { "type": "string" },
        "classroomId": { "type": "string" },
        "folderId": { "type": "string" },
        "name": { "type": "string" },
        "initials": { "type": "string" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "age": { "type": "string" },
        "contact": { "type": "string" },
        "memo": { "type": "string" },
        "inactiveAt": { "type": "string", "format": "date-time" },
        "deletedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerUid", "classroomId", "name", "initials", "order", "createdAt", "updatedAt"]
    },
    "ClassroomDateRecord": {
      "title": "Classroom Date Record",
      "description": "Per-date classroom record",
      "type": "object",
      "properties": {
        "classroomId": { "type": "string" },
        "classroomName": { "type": "string" },
        "folderId": { "type": "string" },
        "folderName": { "type": "string" },
        "date": { "type": "string" },
        "ownerUid": { "type": "string" },
        "contentIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "attendance": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "studentId": { "type": "string" },
              "status": { "type": "string", "enum": ["Present", "Absent", "Late"] },
              "isExcluded": { "type": "boolean" }
            }
          }
        },
        "memo": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["classroomId", "date", "ownerUid", "contentIds", "attendance", "memo", "createdAt", "updatedAt"]
    },
    "Memo": {
      "title": "Memo",
      "description": "General memo",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "date": { "type": "string" },
        "ownerUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "date", "ownerUid"]
    },
    "LessonCategory": {
      "title": "Lesson Category",
      "description": "Content category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerUid": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["name", "ownerUid"]
    },
    "LessonContent": {
      "title": "Lesson Content",
      "description": "Content detail",
      "type": "object",
      "properties": {
        "categoryId": { "type": ["string", "null"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "html": { "type": "string" },
        "ownerUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "order": { "type": "number" }
      },
      "required": ["title", "ownerUid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile"
    },
    "/classrooms/{classroomId}": {
      "schema": "Classroom",
      "description": "Primary classroom documents"
    },
    "/folders/{folderId}": {
      "schema": "Classroom",
      "description": "Legacy classroom documents kept during migration"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Global students"
    },
    "/classroomDateRecords/{recordId}": {
      "schema": "ClassroomDateRecord",
      "description": "Primary classroom date records"
    },
    "/folderDateRecords/{recordId}": {
      "schema": "ClassroomDateRecord",
      "description": "Legacy classroom date records kept during migration"
    },
    "/memos/{memoId}": {
      "schema": "Memo",
      "description": "Memo list"
    },
    "/categories/{categoryId}": {
      "schema": "LessonCategory",
      "description": "Content categories"
    },
    "/contents/{contentId}": {
      "schema": "LessonContent",
      "description": "Content items"
    }
  }
}
