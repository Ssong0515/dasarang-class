{
  "entities": {
    "User": {
      "title": "User",
      "description": "Admin or teacher profile",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "teacher"] }
      },
      "required": ["email"]
    },
    "LessonFolder": {
      "title": "Lesson Folder",
      "description": "Class folder",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerUid"]
    },
    "Student": {
      "title": "Student",
      "description": "Global student master record",
      "type": "object",
      "properties": {
        "ownerUid": { "type": "string" },
        "folderId": { "type": "string" },
        "name": { "type": "string" },
        "initials": { "type": "string" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "age": { "type": "string" },
        "contact": { "type": "string" },
        "memo": { "type": "string" },
        "inactiveAt": { "type": "string", "format": "date-time" },
        "deletedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerUid", "folderId", "name", "initials", "order", "createdAt", "updatedAt"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "Per-date class record",
      "type": "object",
      "properties": {
        "folderId": { "type": "string" },
        "folderName": { "type": "string" },
        "date": { "type": "string" },
        "title": { "type": "string" },
        "ownerUid": { "type": "string" },
        "attendance": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "studentId": { "type": "string" },
              "status": { "type": "string", "enum": ["Present", "Absent", "Late"] },
              "isExcluded": { "type": "boolean" }
            }
          }
        },
        "resources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string", "enum": ["pdf", "link"] },
              "info": { "type": "string" }
            }
          }
        },
        "memo": { "type": "string" },
        "summary": {
          "type": "object",
          "properties": {
            "text": { "type": "string" },
            "attendanceRate": { "type": "string" },
            "engagement": { "type": "string" },
            "resourceCount": { "type": "string" }
          }
        }
      },
      "required": ["folderId", "date", "ownerUid"]
    },
    "Memo": {
      "title": "Memo",
      "description": "General memo",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "date": { "type": "string" },
        "ownerUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "date", "ownerUid"]
    },
    "LessonCategory": {
      "title": "Lesson Category",
      "description": "Content category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerUid": { "type": "string" }
      },
      "required": ["name", "ownerUid"]
    },
    "LessonContent": {
      "title": "Lesson Content",
      "description": "Content detail",
      "type": "object",
      "properties": {
        "categoryId": { "type": "string" },
        "title": { "type": "string" },
        "html": { "type": "string" },
        "ownerUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["categoryId", "title", "ownerUid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile"
    },
    "/folders/{folderId}": {
      "schema": "LessonFolder",
      "description": "Class folders"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Global students"
    },
    "/folderDateRecords/{recordId}": {
      "schema": "Lesson",
      "description": "Lesson records"
    },
    "/memos/{memoId}": {
      "schema": "Memo",
      "description": "Memo list"
    },
    "/categories/{categoryId}": {
      "schema": "LessonCategory",
      "description": "Content categories"
    },
    "/contents/{contentId}": {
      "schema": "LessonContent",
      "description": "Content items"
    }
  }
}
