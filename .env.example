# GEMINI_API_KEY: Required for server-side Gemini translation requests.
# Keep this only on the Lightsail server in `.env`.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# In Lightsail production, set this to the public HTTPS URL for the app.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://15.164.105.38/dasarang-class"

# APP_BASE_PATH: Public path prefix when this app is mounted behind Nginx.
# Use "/" for root deployments, or "/dasarang-class" for the current Lightsail plan.
APP_BASE_PATH="/dasarang-class"

# PORT / HOST: Local bind address for the Node server behind Nginx.
# Keep HOST at 0.0.0.0 unless you have a specific binding requirement.
PORT="3100"
HOST="0.0.0.0"

# NODE_ENV: Must be production on the Lightsail server so Express serves the built dist assets.
NODE_ENV="production"

# GEMINI_TRANSLATION_MODEL: Optional override for the server-side translation model.
GEMINI_TRANSLATION_MODEL="gemini-3-flash-preview"

# GOOGLE_SPREADSHEET_ID: Existing Google Sheets file ID used as the Gemini-readable student source.
GOOGLE_SPREADSHEET_ID="YOUR_GOOGLE_SPREADSHEET_ID"

# GOOGLE_SERVICE_ACCOUNT_JSON: Optional full JSON for a service account that can edit the spreadsheet.
# Alternative to the three GOOGLE_SERVICE_ACCOUNT_* fields below.
GOOGLE_SERVICE_ACCOUNT_JSON='{"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}'

# GOOGLE_SERVICE_ACCOUNT_*: Optional split credentials for the Google Sheets service account.
GOOGLE_SERVICE_ACCOUNT_PROJECT_ID="YOUR_GOOGLE_PROJECT_ID"
GOOGLE_SERVICE_ACCOUNT_EMAIL="service-account@project.iam.gserviceaccount.com"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# FIREBASE_SERVICE_ACCOUNT_JSON: Optional Firebase Admin service account for server-side Firestore access.
# If omitted, the server falls back to GOOGLE_SERVICE_ACCOUNT_JSON or application default credentials.
FIREBASE_SERVICE_ACCOUNT_JSON='{"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}'

# FIREBASE_SERVICE_ACCOUNT_*: Optional split credentials for Firebase Admin.
FIREBASE_SERVICE_ACCOUNT_PROJECT_ID="YOUR_FIREBASE_PROJECT_ID"
FIREBASE_SERVICE_ACCOUNT_EMAIL="firebase-adminsdk@project.iam.gserviceaccount.com"
FIREBASE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
