rules_version = '2';
// Updated: 2026-05-19
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerUid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.uid == 'dev-admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         exists(/databases/$(database)/documents/admins/$(request.auth.token.email)) ||
         request.auth.token.email == "songes0515@gmail.com" ||
         request.auth.token.email == "damunacenter@gmail.com");
    }

    function isRegisteredStudent() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/studentAccess/$(request.auth.token.email));
    }

    function canReadStudentPage() {
      return isAdmin() || isRegisteredStudent();
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email']) &&
             data.email is string &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('role' in data) || data.role in ['admin', 'teacher']);
    }

    function isValidClassroom(data) {
      return data.keys().hasAll(['name', 'ownerUid']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (data.ownerUid == request.auth.uid || isAdmin()) &&
             !('students' in data) &&
             (!('assignedContentIds' in data) || data.assignedContentIds is list) &&
             (!('isOpen' in data) || data.isOpen is bool) &&
             (!('order' in data) || data.order is number) &&
             (!('icon' in data) || data.icon is string) &&
             (!('color' in data) || data.color is string) &&
             (!('createdAt' in data) || data.createdAt is string) &&
             (!('driveFolderId' in data) || data.driveFolderId is string) &&
             (!('driveFolderName' in data) || data.driveFolderName is string);
    }

    function isValidLesson(data) {
      return data.keys().hasAll(['date', 'ownerUid', 'classroomId']) &&
             data.date is string &&
             data.classroomId is string &&
             (!('classroomName' in data) || data.classroomName is string) &&
             (data.ownerUid == request.auth.uid || isAdmin());
    }

    function isValidClassroomDateRecord(data) {
      return data.keys().hasAll([
               'date',
               'ownerUid',
               'classroomId',
               'classroomName',
               'contentIds',
               'attendance',
               'memo',
               'createdAt',
               'updatedAt'
             ]) &&
             data.classroomId is string &&
             data.classroomName is string &&
             data.date is string &&
             data.contentIds is list &&
             data.attendance is list &&
             data.memo is string &&
             data.createdAt is string &&
             data.updatedAt is string &&
             (data.ownerUid == request.auth.uid || isAdmin());
    }

    function isValidStudent(data) {
      return data.keys().hasAll([
               'ownerUid',
               'classroomId',
               'name',
               'initials',
               'order',
               'createdAt',
               'updatedAt'
             ]) &&
             data.classroomId is string &&
             (data.ownerUid == request.auth.uid || isAdmin()) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.initials is string && data.initials.size() < 10 &&
             data.order is number &&
             data.createdAt is string &&
             data.updatedAt is string &&
             (!('age' in data) || data.age is string) &&
             (!('contact' in data) || data.contact is string) &&
             (!('memo' in data) || data.memo is string) &&
             (!('inactiveAt' in data) || data.inactiveAt is string) &&
             (!('deletedAt' in data) || data.deletedAt is string);
    }

    function isValidMemo(data) {
      return data.keys().hasAll(['content', 'date', 'ownerUid']) &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.date is string &&
             (data.ownerUid == request.auth.uid || isAdmin());
    }

    function isValidDailyReview(data) {
      return data.keys().hasAll([
               'date',
               'ownerUid',
               'summary',
               'sourceRecordIds',
               'createdAt',
               'updatedAt'
             ]) &&
             data.date is string &&
             data.ownerUid == request.auth.uid &&
             data.summary is string && data.summary.size() > 0 && data.summary.size() < 5000 &&
             data.sourceRecordIds is list &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    // 수정 시에는 원 작성자가 아니어도 관리자면 편집 가능. 단 ownerUid는 기존 값 그대로 유지해야 한다.
    function isValidDailyReviewUpdate(data, prev) {
      return data.keys().hasAll([
               'date',
               'ownerUid',
               'summary',
               'sourceRecordIds',
               'createdAt',
               'updatedAt'
             ]) &&
             data.date is string &&
             data.ownerUid is string && data.ownerUid == prev.ownerUid &&
             data.summary is string && data.summary.size() > 0 && data.summary.size() < 5000 &&
             data.sourceRecordIds is list &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'ownerUid']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('order' in data) || data.order is number) &&
             (data.ownerUid == request.auth.uid || isAdmin());
    }

    function isValidContent(data) {
      return data.keys().hasAll(['categoryId', 'title', 'ownerUid']) &&
             (data.categoryId is string || data.categoryId == null) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             (!('html' in data) || data.html is string) &&
             (!('slideUrl' in data) || data.slideUrl is string) &&
             (!('order' in data) || data.order is number) &&
             (!('sourceDriveFileId' in data) || data.sourceDriveFileId is string) &&
             (!('convertedDriveFileId' in data) || data.convertedDriveFileId is string) &&
             (!('sourceModifiedTime' in data) || data.sourceModifiedTime is string || data.sourceModifiedTime == null) &&
             (!('syncedAt' in data) || data.syncedAt is string) &&
             (!('syncProvider' in data) || data.syncProvider == 'notebooklm-drive-folder') &&
             (data.ownerUid == request.auth.uid || isAdmin());
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /classrooms/{classroomId} {
      allow read: if canReadStudentPage();
      allow create: if isAdmin() && isValidClassroom(request.resource.data);
      allow update: if isDocOwner() || isAdmin();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /lessons/{lessonId} {
      allow read: if canReadStudentPage();
      allow create: if isAdmin() && isValidLesson(request.resource.data);
      allow update: if isDocOwner() || isAdmin();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /classroomDateRecords/{recordId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidClassroomDateRecord(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && isValidClassroomDateRecord(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /students/{studentId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidStudent(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && isValidStudent(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /memos/{memoId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAdmin() && isValidMemo(request.resource.data);
      allow update: if isDocOwner() || isAdmin();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /dailyReviews/{reviewId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidDailyReview(request.resource.data);
      allow update: if isAdmin() && isValidDailyReviewUpdate(request.resource.data, resource.data);
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if canReadStudentPage();
      allow create: if isAdmin() && isValidCategory(request.resource.data);
      allow update: if isDocOwner() || isAdmin();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /contents/{contentId} {
      allow read: if canReadStudentPage();
      allow create: if isAdmin() && isValidContent(request.resource.data);
      allow update: if isDocOwner() || isAdmin();
      allow delete: if isDocOwner() || isAdmin();
    }

    function isValidPublishedLesson(data) {
      return data.keys().hasAll(['classroomId', 'date', 'publishedContentIds', 'ownerUid', 'updatedAt']) &&
             data.classroomId is string &&
             data.date is string &&
             data.publishedContentIds is list &&
             data.updatedAt is string &&
             (!('classroomName' in data) || data.classroomName is string) &&
             (data.ownerUid == request.auth.uid || isAdmin());
    }

    // 학생이 읽을 수 있는 유일한 수업 데이터 — 강사가 '공개'한 실습 블록 id만 담는다 (출석·메모 제외).
    match /publishedLessons/{docId} {
      allow read: if canReadStudentPage();
      allow create, update: if isAdmin() && isValidPublishedLesson(request.resource.data);
      allow delete: if isAdmin();
    }

    match /studentAccess/{email} {
      allow get: if isAdmin() || (isAuthenticated() && request.auth.token.email == email);
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /access_logs/{logId} {
      allow read: if isAdmin();
      allow create: if canReadStudentPage() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == request.auth.token.email;
      allow update, delete: if isAdmin();
    }

    function isValidCurriculum(data) {
      return data.keys().hasAll(['title', 'ownerUid', 'sessions', 'createdAt', 'updatedAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.sessions is list &&
             (!('description' in data) || data.description is string) &&
             (!('order' in data) || data.order is number) &&
             (data.ownerUid == request.auth.uid || isAdmin());
    }

    match /curriculums/{curriculumId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() && isValidCurriculum(request.resource.data);
      allow delete: if isAdmin();
    }

    // 공개 노출은 서버(/api/public/student-posts, admin SDK)를 통해서만 — 클라이언트는 관리자만
    match /studentPosts/{postId} {
      allow read, write: if isAdmin();
    }

    function isValidStudentVoiceMessage(data) {
      return data.keys().hasAll([
               'classroomId',
               'date',
               'sourceLang',
               'sourceText',
               'koreanText',
               'translationOk',
               'createdAt'
             ]) &&
             data.classroomId is string &&
             data.date is string &&
             data.sourceLang is string &&
             data.sourceText is string && data.sourceText.size() > 0 && data.sourceText.size() < 5000 &&
             data.koreanText is string && data.koreanText.size() < 5000 &&
             data.translationOk is bool &&
             data.createdAt is string &&
             (!('classroomName' in data) || data.classroomName is string);
    }

    // 외국인 학생이 말한 걸 한국어로 번역해 강사에게 보내는 실시간 채팅.
    // 공용 학생 계정이 create, 읽기·수정·삭제는 강사(관리자)만 — 학생끼리 서로 못 읽는다.
    match /studentVoiceMessages/{messageId} {
      allow create: if canReadStudentPage() && isValidStudentVoiceMessage(request.resource.data);
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
