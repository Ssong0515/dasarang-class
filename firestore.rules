rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerUid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "songes0515@gmail.com");
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email']) &&
             data.email is string &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('role' in data) || data.role in ['admin', 'teacher']);
    }

    function isValidClassroom(data) {
      return data.keys().hasAll(['name', 'ownerUid']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (data.ownerUid == request.auth.uid || isAdmin()) &&
             !('students' in data) &&
             (!('assignedContentIds' in data) || data.assignedContentIds is list) &&
             (!('isOpen' in data) || data.isOpen is bool) &&
             (!('order' in data) || data.order is number) &&
             (!('icon' in data) || data.icon is string) &&
             (!('color' in data) || data.color is string) &&
             (!('createdAt' in data) || data.createdAt is string) &&
             (!('driveFolderId' in data) || data.driveFolderId is string) &&
             (!('driveFolderName' in data) || data.driveFolderName is string);
    }

    function isValidLesson(data) {
      return data.keys().hasAll(['date', 'ownerUid', 'classroomId']) &&
             data.date is string &&
             data.classroomId is string &&
             (!('classroomName' in data) || data.classroomName is string) &&
             (data.ownerUid == request.auth.uid || isAdmin());
    }

    function isValidClassroomDateRecord(data) {
      return data.keys().hasAll([
               'date',
               'ownerUid',
               'classroomId',
               'classroomName',
               'contentIds',
               'attendance',
               'memo',
               'createdAt',
               'updatedAt'
             ]) &&
             data.classroomId is string &&
             data.classroomName is string &&
             data.date is string &&
             data.contentIds is list &&
             data.attendance is list &&
             data.memo is string &&
             data.createdAt is string &&
             data.updatedAt is string &&
             (data.ownerUid == request.auth.uid || isAdmin());
    }

    function isValidStudent(data) {
      return data.keys().hasAll([
               'ownerUid',
               'classroomId',
               'name',
               'initials',
               'order',
               'createdAt',
               'updatedAt'
             ]) &&
             data.classroomId is string &&
             (data.ownerUid == request.auth.uid || isAdmin()) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.initials is string && data.initials.size() < 10 &&
             data.order is number &&
             data.createdAt is string &&
             data.updatedAt is string &&
             (!('age' in data) || data.age is string) &&
             (!('contact' in data) || data.contact is string) &&
             (!('memo' in data) || data.memo is string) &&
             (!('inactiveAt' in data) || data.inactiveAt is string) &&
             (!('deletedAt' in data) || data.deletedAt is string);
    }

    function isValidMemo(data) {
      return data.keys().hasAll(['content', 'date', 'ownerUid']) &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.date is string &&
             (data.ownerUid == request.auth.uid || isAdmin());
    }

    function isValidDailyReview(data) {
      return data.keys().hasAll([
               'date',
               'ownerUid',
               'summary',
               'sourceRecordIds',
               'createdAt',
               'updatedAt'
             ]) &&
             data.date is string &&
             data.ownerUid == request.auth.uid &&
             data.summary is string && data.summary.size() > 0 && data.summary.size() < 5000 &&
             data.sourceRecordIds is list &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'ownerUid']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('order' in data) || data.order is number) &&
             (data.ownerUid == request.auth.uid || isAdmin());
    }

    function isValidContent(data) {
      return data.keys().hasAll(['categoryId', 'title', 'ownerUid']) &&
             (data.categoryId is string || data.categoryId == null) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             (!('html' in data) || data.html is string) &&
             (!('order' in data) || data.order is number) &&
             (data.ownerUid == request.auth.uid || isAdmin());
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /classrooms/{classroomId} {
      allow read: if true;
      allow create: if isAdmin() && isValidClassroom(request.resource.data);
      allow update: if isDocOwner() || isAdmin();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /lessons/{lessonId} {
      allow read: if true;
      allow create: if isAdmin() && isValidLesson(request.resource.data);
      allow update: if isDocOwner() || isAdmin();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /classroomDateRecords/{recordId} {
      allow read: if true;
      allow create: if isAdmin() && isValidClassroomDateRecord(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && isValidClassroomDateRecord(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /students/{studentId} {
      allow read: if true;
      allow create: if isAdmin() && isValidStudent(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && isValidStudent(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /memos/{memoId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAdmin() && isValidMemo(request.resource.data);
      allow update: if isDocOwner() || isAdmin();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /dailyReviews/{reviewId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidDailyReview(request.resource.data);
      allow update: if isAdmin() && isValidDailyReview(request.resource.data);
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCategory(request.resource.data);
      allow update: if isDocOwner() || isAdmin();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /contents/{contentId} {
      allow read: if true;
      allow create: if isAdmin() && isValidContent(request.resource.data);
      allow update: if isDocOwner() || isAdmin();
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
